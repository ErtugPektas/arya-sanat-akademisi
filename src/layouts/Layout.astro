---
import defaultSiteSettings from '../content/site-settings.json';
import fs from 'fs';
import path from 'path';

let siteSettings = defaultSiteSettings;
try {
  const settingsPath = path.resolve(process.cwd(), 'src/content/site-settings.json');
  if (fs.existsSync(settingsPath)) {
    siteSettings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
  }
} catch (e) {
  console.error("Failed to read site-settings.json dynamically:", e);
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  schemaJson?: string;
}

const {
  title = siteSettings.seo.title,
  description = siteSettings.seo.description,
  keywords = "müzik kursu kayseri, gitar dersi kayseri, piyano dersi kayseri, bateri dersi kayseri, keman dersi kayseri, müzik okulu kayseri, Arya Sanat Akademisi, MEB onaylı müzik sertifikası",
  canonical = "https://arya-sanat-akademisi.vercel.app/",
  ogTitle,
  ogDescription,
  ogImage = "https://arya-sanat-akademisi.vercel.app/assets/hero_bg.png",
  schemaJson
} = Astro.props;

const currentOgTitle = ogTitle || title;
const currentOgDescription = ogDescription || description;
const isAdmin = Astro.url.pathname.startsWith('/admin');
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#09090e" />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Arya Sanat Akademisi" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={canonical} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:title" content={currentOgTitle} />
  <meta property="og:description" content={currentOgDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Arya Sanat Akademisi" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={currentOgTitle} />
  <meta name="twitter:description" content={currentOgDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css?v=106" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />

  <!-- Dynamic Schema.org injection -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}

  <!-- Netlify Identity (Required for Decap CMS Login) -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>

  <!-- GSAP, ScrollTrigger & Draggable Animation Libraries -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Draggable.min.js" is:inline></script>

  <title>{title}</title>
  <slot name="head" />
</head>
<body>

  <!-- ===== HEADER / NAV ===== -->
  {!isAdmin && (
    <header class={`site-header ${Astro.url.pathname !== '/' ? 'scrolled' : ''}`} id="site-header" role="banner">
      <nav class="navbar" aria-label="Ana Navigasyon">
        <div class="nav-container">

          <!-- Logo -->
          <a href="/#hero" class="logo" aria-label="Arya Sanat Akademisi Ana Sayfa">
            <span class="logo-icon" aria-hidden="true">♩</span>
            <div class="logo-text">
              <span class="logo-title">Arya Sanat</span>
              <span class="logo-subtitle">Akademisi</span>
            </div>
          </a>

          <!-- Desktop Nav Links -->
          {siteSettings.navbar && siteSettings.navbar.links ? (
            <ul class="nav-links" role="list">
              {siteSettings.navbar.links.map(link => (
                <li><a href={link.url} class="nav-link">{link.text}</a></li>
              ))}
            </ul>
          ) : (
            <ul class="nav-links" role="list">
              <li><a href="/#courses" class="nav-link">Eğitimler</a></li>
              <li><a href="/#announcements" class="nav-link">Duyurular</a></li>
              <li><a href="/#why-arya" class="nav-link">Neden Biz?</a></li>
              <li><a href="/#gallery" class="nav-link">Galerimiz</a></li>
              <li><a href="/#contact" class="nav-link">İletişim</a></li>
            </ul>
          )}

          <!-- Nav Right -->
          <div class="nav-right">
            <!-- Mute Button -->
            <button class="mute-btn" id="muteBtn" aria-label="Sesi kapat veya aç" title="Sesi Kapat / Aç">
              <svg id="soundOnIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
              </svg>
              <svg id="soundOffIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                <line x1="23" y1="9" x2="17" y2="15"></line>
                <line x1="17" y1="9" x2="23" y2="15"></line>
              </svg>
            </button>
            <a href="/#contact" class="btn btn-primary nav-cta" id="navCta">{siteSettings.navbar ? siteSettings.navbar.ctaText : "Kayıt Ol"}</a>
            <!-- Hamburger -->
            <button class="hamburger" id="hamburger" aria-label="Menüyü aç veya kapat" aria-expanded="false" aria-controls="mobileMenu">
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
            </button>
          </div>

        </div>

        <!-- Mobile Menu -->
        <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Mobil Menü" aria-hidden="true">
          <ul class="mobile-nav-links" role="list">
            {siteSettings.navbar && siteSettings.navbar.links ? (
              siteSettings.navbar.links.map(link => (
                <li><a href={link.url} class="mobile-nav-link">{link.text}</a></li>
              ))
            ) : (
              <>
                <li><a href="/#courses" class="mobile-nav-link">Eğitimler</a></li>
                <li><a href="/#announcements" class="mobile-nav-link">Duyurular</a></li>
                <li><a href="/#why-arya" class="mobile-nav-link">Neden Biz?</a></li>
                <li><a href="/#gallery" class="mobile-nav-link">Galerimiz</a></li>
                <li><a href="/#contact" class="mobile-nav-link">İletişim</a></li>
              </>
            )}
            <li><a href="/#contact" class="btn btn-primary mobile-cta">{siteSettings.navbar ? siteSettings.navbar.ctaText : "Kayıt Ol"}</a></li>
          </ul>
        </div>
      </nav>
    </header>
  )}

  <!-- Content Slot -->
  <slot />

  <!-- Page View Tracking -->
  {!isAdmin && (
    <script is:inline>
      fetch('/api/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path: window.location.pathname })
      }).catch(() => {});
    </script>
  )}

  <!-- ===== FOOTER ===== -->
  {!isAdmin && (
    <>
      <footer class="site-footer" role="contentinfo">
        <div class="container">
          <div class="footer-grid">

            <!-- Brand -->
            <div class="footer-brand">
              <a href="/#hero" class="logo footer-logo" aria-label="Arya Sanat Akademisi Ana Sayfa">
                <span class="logo-icon" aria-hidden="true">♩</span>
                <div class="logo-text">
                  <span class="logo-title">Arya Sanat</span>
                  <span class="logo-subtitle">Akademisi</span>
                </div>
              </a>
              <p class="footer-tagline">
                Müziğin gücüyle hayatınıza değer katıyoruz. On yılı aşkın deneyimle
                Kayseri'nin en güvenilir müzik akademisi.
              </p>
            </div>

            <!-- Quick Links -->
            <nav class="footer-nav" aria-label="Hızlı Linkler">
              <h3 class="footer-heading">Hızlı Linkler</h3>
              <ul class="footer-links" role="list">
                <li><a href="/#hero" class="footer-link">Ana Sayfa</a></li>
                <li><a href="/#courses" class="footer-link">Eğitimler</a></li>
                <li><a href="/#why-arya" class="footer-link">Neden Biz?</a></li>
                <li><a href="/#teachers" class="footer-link">Eğitmenler</a></li>
                <li><a href="/#contact" class="footer-link">İletişim</a></li>
              </ul>
            </nav>

            <!-- Courses Links -->
            <nav class="footer-nav" aria-label="Kurs Bağlantıları">
              <h3 class="footer-heading">Kurslarımız</h3>
              <ul class="footer-links" role="list">
                <li><a href="/kurslar/bateri" class="footer-link">Bateri Dersi</a></li>
                <li><a href="/kurslar/gitar" class="footer-link">Gitar Dersi</a></li>
                <li><a href="/kurslar/piyano" class="footer-link">Piyano Dersi</a></li>
                <li><a href="/kurslar/telli-uflemeli" class="footer-link">Keman &amp; Telli</a></li>
              </ul>
            </nav>

            <!-- Contact Quick -->
            <div class="footer-contact">
              <h3 class="footer-heading">İletişim</h3>
              <address class="footer-address" aria-label="Kısa iletişim bilgileri">
                <p>📍 {siteSettings.contact.address}</p>
                <p><a href={`tel:${siteSettings.contact.phone.replace(/[^\d+]/g, '')}`}>📞 {siteSettings.contact.phone}</a></p>
                <p><a href={`mailto:${siteSettings.contact.email}`}>✉️ {siteSettings.contact.email}</a></p>
              </address>
            </div>

          </div>

          <div class="footer-bottom">
            <p class="footer-copy">
              &copy; <span id="currentYear"></span> Arya Sanat Akademisi. Tüm hakları saklıdır.
            </p>
            <div class="footer-social" aria-label="Sosyal medya">
              <a href="#" class="footer-social-link" id="footerInstagram" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
              <a href="#" class="footer-social-link" id="footerYoutube" aria-label="YouTube">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 1.96A29 29 0 0 0 1 12a29 29 0 0 0-.46-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon></svg>
              </a>
            </div>
          </div>
        </div>
      </footer>

      <!-- ===== FLOATING BUTTONS ===== -->
      <!-- WhatsApp -->
      <a
        href={`https://wa.me/${siteSettings.contact.whatsapp}?text=Merhaba%2C%20ücretsiz%20deneme%20dersi%20hakkında%20bilgi%20almak%20istiyorum.`}
        class="whatsapp-float"
        id="whatsappFloat"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp üzerinden bizimle iletişime geçin"
        title="WhatsApp'tan Ulaşın"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        <span class="whatsapp-pulse" aria-hidden="true"></span>
      </a>

      <!-- Back to Top -->
      <button class="back-to-top" id="backToTop" aria-label="Sayfanın başına dön" title="Başa Dön" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m18 15-6-6-6 6"/></svg>
      </button>


      <!-- JS Files -->
      <script src="/js/audio.js" is:inline></script>
      <script src="/js/main.js" is:inline></script>

      <!-- Netlify Identity redirect control -->
      <script is:inline>
        if (window.netlifyIdentity) {
          window.netlifyIdentity.on("init", user => {
            if (!user) {
              window.netlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
              });
            }
          });
        }
      </script>
    </>
  )}
</body>
</html>
