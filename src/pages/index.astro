---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import duyurular from '../content/duyurular.json';
import siteSettings from '../content/site-settings.json';

const courses = await getCollection('kurslar');

const cleanPhone = siteSettings.contact.phone.replace(/[^\d+]/g, '');

const schema = {
  "@context": "https://schema.org",
  "@type": "MusicSchool",
  "name": "Arya Sanat Akademisi",
  "description": siteSettings.seo.description,
  "url": "https://arya-sanat-akademisi.vercel.app",
  "logo": "https://arya-sanat-akademisi.vercel.app/assets/favicon.svg",
  "image": "https://arya-sanat-akademisi.vercel.app/assets/hero_bg.png",
  "telephone": cleanPhone,
  "email": siteSettings.contact.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteSettings.contact.address,
    "addressLocality": siteSettings.stats.location || "Kocasinan",
    "addressRegion": "Kayseri",
    "postalCode": "38020",
    "addressCountry": "TR"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "21:00"
  },
  "sameAs": [
    "https://www.instagram.com/aryasanatakademisi",
    "https://www.facebook.com/aryasanatakademisi"
  ],
  "priceRange": "$$",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.7337,
    "longitude": 35.5186
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Müzik Eğitim Programları",
    "itemListElement": courses.map(course => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Course",
        "name": `${course.data.title} Kursu`,
        "description": course.data.description,
        "provider": {
          "@type": "LocalBusiness",
          "name": "Arya Sanat Akademisi",
          "url": "https://arya-sanat-akademisi.vercel.app"
        }
      }
    }))
  }
};
---

<Layout
  title="Arya Sanat Akademisi — Profesyonel Müzik Eğitimi | Kayseri "
  description="Kayseri Kocasinan'ın en iyi müzik akademisi. Bateri, Gitar, Piyano, Keman eğitimleri. MEB onaylı sertifika. Ücretsiz deneme dersi!"
  keywords="müzik kursu kayseri, gitar dersi kocasinan, piyano dersi kayseri, bateri dersi, keman dersi kayseri, müzik okulu kocasinan, Arya Sanat Akademisi, MEB onaylı müzik sertifikası, çocuk müzik kursu"
  schemaJson={JSON.stringify(schema)}
>
  <main id="main-content">

    <!-- ===== HERO SECTION ===== -->
    <section class="hero" id="hero" aria-label="Arya Sanat Akademisi Ana Bölümü">
      <div class="hero-bg" aria-hidden="true">
        <img
          src="/assets/hero_bg.png"
          alt="Profesyonel müzik akademisi — sahne aydınlatması altında kuyruklu piyano"
          class="hero-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay" aria-hidden="true"></div>
      </div>

      <div class="hero-content">
        <p class="hero-tag">{siteSettings.hero.tag}</p>
        <h1 class="hero-title">
          {siteSettings.hero.title}<br />
          <span class="hero-title-highlight">{siteSettings.hero.titleHighlight}</span>
        </h1>
        <p class="hero-desc">
          {siteSettings.hero.desc}
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary btn-lg" id="heroCta">
            Ücretsiz Deneme Dersi Al
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#courses" class="btn btn-outline btn-lg" id="heroCoursesBtn">
            Kursları Keşfet
          </a>
        </div>
        <div class="hero-stats" role="list" aria-label="Akademi İstatistikleri">
          <div class="hero-stat" role="listitem">
            <strong>{siteSettings.stats.studentsCount}</strong>
            <span>Mutlu Öğrenci</span>
          </div>
          <div class="hero-stat-divider" aria-hidden="true"></div>
          <div class="hero-stat" role="listitem">
            <strong>{siteSettings.stats.teachersCount}</strong>
            <span>Uzman Eğitmen</span>
          </div>
          <div class="hero-stat-divider" aria-hidden="true"></div>
          <div class="hero-stat" role="listitem">
            <strong>{siteSettings.stats.experienceYears}</strong>
            <span>Yıllık Deneyim</span>
          </div>
        </div>
      </div>

      <a href="#announcements" class="scroll-indicator" aria-label="Aşağı kaydır">
        <div class="scroll-dot"></div>
      </a>
    </section>

    <!-- ===== ANNOUNCEMENTS SECTION ===== -->
    <section class="section announcements-section" id="announcements" aria-labelledby="announcementsHeading" style="background: #0b0b0e; border-top: 1px solid #1c1c28; border-bottom: 1px solid #1c1c28; padding: 5rem 0;">
      <div class="container">
        <header class="section-header" style="margin-bottom: 3.5rem; text-align: center; max-width: 700px; margin-left: auto; margin-right: auto;">
          <p class="section-tag" style="color: #d4af37; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 0.5rem;">Duyuru &amp; Fırsatlar</p>
          <h2 id="announcementsHeading" class="section-title" style="font-size: 2.5rem; font-family: 'Playfair Display', serif; font-weight: 700; color: #fff; margin: 0; line-height: 1.2;">Duyurular &amp; Kampanyalar</h2>
          <p class="section-desc" style="color: #8b8b9f; font-size: 1rem; margin-top: 0.75rem; line-height: 1.6;">Akademimizden güncel duyurular, etkinlik haberleri ve avantajlı kayıt dönemleri.</p>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
          {duyurular.map((duyuru) => (
            <article style="background: #101016; border: 1px solid #1f1f2e; border-radius: 16px; padding: 2.25rem 2rem; position: relative; transition: all 0.3s; display: flex; flex-direction: column; justify-content: space-between; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
              <div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                  <span style={`background: ${duyuru.badge === 'Kampanya' ? 'rgba(212,175,55,0.08)' : 'rgba(30,144,255,0.08)'}; color: ${duyuru.badge === 'Kampanya' ? '#d4af37' : '#1e90ff'}; border: 1px solid ${duyuru.badge === 'Kampanya' ? 'rgba(212,175,55,0.15)' : 'rgba(30,144,255,0.15)'}; padding: 0.35rem 0.85rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;`}>
                    {duyuru.badge}
                  </span>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-family: monospace;">{duyuru.date}</span>
                </div>
                <h3 style="font-size: 1.4rem; font-weight: 700; color: #fff; margin: 0 0 1rem 0; font-family: 'Playfair Display', serif; line-height: 1.3;">{duyuru.title}</h3>
                <p style="color: #b4b4c6; font-size: 0.925rem; line-height: 1.65; margin: 0 0 2rem 0;">{duyuru.content}</p>
              </div>
              <a href="#contact" style="color: #d4af37; text-decoration: none; font-size: 0.875rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.35rem; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#d4af37'">
                Detaylı Bilgi &amp; İletişim
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== COURSES SECTION ===== -->
    <section class="section courses-section" id="courses" aria-labelledby="coursesHeading">
      <div class="container">
        <header class="section-header">
          <p class="section-tag">Eğitim Programlarımız</p>
          <h2 id="coursesHeading" class="section-title">Eğitimlerimiz</h2>
          <p class="section-desc">
            Her seviyeye uygun, uzman eğitmenler eşliğinde kapsamlı müzik eğitimleri.
            Başlangıçtan profesyonele giden yolda yanınızdayız.
          </p>
        </header>

        <div class="courses-grid" role="list">
          {courses.map((course) => (
            <article class="course-card" id={`card-${course.id}`} role="listitem" aria-label={`${course.data.heroTitle} eğitimi kartı`}>
              <a href={`/kurslar/${course.id}`} class="card-img-link" aria-label={`${course.data.heroTitle} dersi hakkında detaylı bilgi`}>
                <div class="card-img-wrapper">
                  <img
                    src={course.data.image}
                    alt={`${course.data.heroTitle} dersi — Arya Sanat Akademisi`}
                    class="card-img"
                    loading="lazy"
                    width="420"
                    height="240"
                  />
                  <div class="card-img-overlay" aria-hidden="true"></div>
                </div>
              </a>
              <div class="card-body">
                <div class="card-icon" aria-hidden="true">
                  {course.id === 'bateri' && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <ellipse cx="12" cy="7" rx="9" ry="3"/>
                      <path d="M3 7v10c0 1.66 4 3 9 3s9-1.34 9-3V7"/>
                      <path d="M7 7v10"/>
                      <path d="M17 7v10"/>
                      <path d="m14 3 6-2"/>
                      <path d="m10 3-6-2"/>
                    </svg>
                  )}
                  {course.id === 'gitar' && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18a3.5 3.5 0 0 0 6.1-2.25 3.5 3.5 0 0 0-2.2-6.1A3.5 3.5 0 0 0 9 12a3.5 3.5 0 0 0 0 6Z"/>
                      <path d="m14.5 10.5 6.5-6.5"/>
                      <path d="m18 5 1-1"/>
                      <path d="m16 7 1-1"/>
                      <path d="m15.5 10.5-3-3"/>
                    </svg>
                  )}
                  {course.id === 'piyano' && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="3" width="20" height="18" rx="2"/>
                      <path d="M6 14v7"/>
                      <path d="M10 14v7"/>
                      <path d="M14 14v7"/>
                      <path d="M18 14v7"/>
                      <path d="M2 14h20"/>
                      <rect x="5" y="3" width="2" height="7" fill="currentColor"/>
                      <rect x="9" y="3" width="2" height="7" fill="currentColor"/>
                      <rect x="13" y="3" width="2" height="7" fill="currentColor"/>
                      <rect x="17" y="3" width="2" height="7" fill="currentColor"/>
                    </svg>
                  )}
                  {course.id === 'telli-uflemeli' && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2v20"/>
                      <path d="M17 5a3 3 0 0 0-3 3c0 2.5 3 3.5 3 6a3 3 0 0 1-6 0"/>
                      <path d="M7 5a3 3 0 0 1 3 3c0 2.5-3 3.5-3 6a3 3 0 0 0 6 0"/>
                      <circle cx="12" cy="18" r="1" fill="currentColor"/>
                    </svg>
                  )}
                </div>
                <h3 class="card-title">{course.data.heroTitle}</h3>
                <p class="card-desc">
                  {course.data.description}
                </p>
                <ul class="card-features" aria-label={`${course.data.heroTitle} eğitim detayları`}>
                  <li><strong>Süre:</strong> {course.data.duration}</li>
                  <li><strong>Sıklık:</strong> {course.data.frequency}</li>
                  <li><strong>Sertifika:</strong> {course.data.certificate}</li>
                </ul>
                <a href={`/kurslar/${course.id}`} class="btn btn-card" id={`${course.id}Btn`}>Detaylı İncele →</a>
              </div>
            </article>
          ))}
        </div><!-- /.courses-grid -->
      </div>
    </section>

    <!-- ===== WHY ARYA SECTION ===== -->
    <section class="section why-section" id="why-arya" aria-labelledby="whyHeading">
      <div class="container">
        <header class="section-header">
          <p class="section-tag">{siteSettings.whyUs ? siteSettings.whyUs.tag : "Fark Yaratan Eğitim"}</p>
          <h2 id="whyHeading" class="section-title">{siteSettings.whyUs ? siteSettings.whyUs.title : "Neden Arya Sanat?"}</h2>
          <p class="section-desc">
            {siteSettings.whyUs ? siteSettings.whyUs.desc : "On yılı aşkın deneyimimiz ve yüzlerce mezun öğrencimizle müzik eğitiminde standartları yeniden belirliyoruz."}
          </p>
        </header>

        <div class="features-grid" role="list">
          {siteSettings.whyUs && siteSettings.whyUs.features ? (
            siteSettings.whyUs.features.filter(feat => feat.title || feat.desc).map((feat, index) => (
              <article 
                class={`feature-card ${index === 1 ? 'feature-card--accent' : ''}`} 
                role="listitem" 
                id={feat.id || `feature-${index}`} 
                style="position: relative; overflow: hidden;"
              >
                {/* Background Image / Hover Image */}
                {feat.image && (
                  <img src={feat.image} alt={feat.title} class="card-image-hover" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease; pointer-events: none; z-index: 0;" />
                )}
                
                {/* Background Hover Video */}
                {feat.videoPreview && (
                  <video 
                    src={feat.videoPreview} 
                    loop 
                    muted 
                    playsinline 
                    class="card-video-preview" 
                    style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease; pointer-events: none; z-index: 0;"
                  ></video>
                )}

                <div class="feature-card-content" style="position: relative; z-index: 1; height: 100%; display: flex; flex-direction: column;">
                  <div class="feature-icon-wrapper" aria-hidden="true">
                    {index === 0 && (
                      <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/>
                        <path d="M6 18.8v-4L2 13"/>
                        <path d="M12 22a7 7 0 0 0 7-7v-3.5"/>
                      </svg>
                    )}
                    {index === 1 && (
                      <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                        <line x1="12" y1="19" x2="12" y2="22"/>
                      </svg>
                    )}
                    {index === 2 && (
                      <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <line x1="10" y1="9" x2="8" y2="9"/>
                      </svg>
                    )}
                    {index > 2 && (
                      <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="m9 12 2 2 4-4"/>
                      </svg>
                    )}
                  </div>
                  
                  <h3 class="feature-title">{feat.title}</h3>
                  <p class="feature-desc">{feat.desc}</p>
                  
                  {feat.items && (
                    <ul class="feature-list" aria-label={`${feat.title} özellikleri`}>
                      {feat.items.split(',').map(item => item.trim()).filter(Boolean).map(item => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))
          ) : null}
        </div>
      </div>
    </section>

    <!-- ===== TEACHERS SECTION ===== -->
    <section class="section teachers-section" id="teachers" aria-labelledby="teachersHeading">
      <div class="container">
        <header class="section-header">
          <p class="section-tag">{siteSettings.teachersSection ? siteSettings.teachersSection.tag : "Uzman Kadromuz"}</p>
          <h2 id="teachersHeading" class="section-title">{siteSettings.teachersSection ? siteSettings.teachersSection.title : "Eğitmenlerimiz"}</h2>
          <p class="section-desc">
            {siteSettings.teachersSection ? siteSettings.teachersSection.desc : "Alanında uzman, sahne deneyimine sahip eğitmenlerimizle müzik yolculuğunuzu güvenle sürdürün."}
          </p>
        </header>

        <div class="teachers-grid" role="list">
          {siteSettings.teachersSection && siteSettings.teachersSection.list && siteSettings.teachersSection.list.length > 0 ? (
            siteSettings.teachersSection.list.map((teacher, index) => (
              <article class="teacher-card" role="listitem" id={`teacher-${index}`}>
                <div class="teacher-img-wrapper" style="position: relative; overflow: hidden;">
                  <img
                    src={teacher.image || '/assets/teachers/default.jpg'}
                    alt={`${teacher.name} — ${teacher.specialty}, Arya Sanat Akademisi`}
                    class="teacher-img"
                    loading="lazy"
                    width="320"
                    height="320"
                  />
                  
                  {/* Background Hover Video */}
                  {teacher.videoPreview && (
                    <video 
                      src={teacher.videoPreview} 
                      loop 
                      muted 
                      playsinline 
                      class="card-video-preview" 
                      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease; pointer-events: none; z-index: 1;"
                    ></video>
                  )}
                  
                  <div class="teacher-overlay" aria-hidden="true" style="z-index: 2;">
                    <p class="teacher-bio">
                      {teacher.bio1}
                    </p>
                  </div>
                </div>
                <div class="teacher-info">
                  <h3 class="teacher-name">{teacher.name}</h3>
                  <p class="teacher-specialty">{teacher.specialty}</p>
                  {teacher.tags && (
                    <div class="teacher-tags" aria-label="Uzmanlık alanları">
                      {teacher.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          ) : (
            <article class="teacher-card" role="listitem" id="teacher-can">
              <div class="teacher-img-wrapper">
                <img
                  src="/assets/teacher_drums.png"
                  alt="Mehmet KAYA — Bateri Eğitmeni, Arya Sanat Akademisi"
                  class="teacher-img"
                  loading="lazy"
                  width="320"
                  height="320"
                />
              </div>
              <div class="teacher-info">
                <h3 class="teacher-name">Mehmet KAYA</h3>
                <p class="teacher-specialty">Bateri Eğitmeni</p>
                <div class="teacher-tags" aria-label="Uzmanlık alanları">
                  <span class="tag">Rock</span>
                  <span class="tag">Jazz</span>
                  <span class="tag">Latin</span>
                </div>
              </div>
            </article>
          )}
        </div>
      </div>
    </section>

    <!-- ===== CONTACT SECTION ===== -->
    <section class="section contact-section" id="contact" aria-labelledby="contactHeading">
      <div class="container">
        <div class="contact-grid">

          <div class="contact-info">
            <p class="section-tag">Bize Ulaşın</p>
            <h2 id="contactHeading" class="section-title contact-title">İletişim &amp; Kayıt</h2>
            <p class="contact-desc">
              Ücretsiz deneme dersimiz için formu doldurun veya doğrudan bizimle iletişime geçin.
              Sizi müzik yolculuğunuzda karşılamak için sabırsızlanıyoruz.
            </p>

            <address class="contact-details" aria-label="Akademi iletişim bilgileri">
              <div class="contact-item">
                <span class="contact-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <div>
                  <strong>Adres</strong>
                  <p>{siteSettings.contact.address}</p>
                </div>
              </div>
              <div class="contact-item">
                <span class="contact-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </span>
                <div>
                  <strong>Telefon</strong>
                  <p><a href={`tel:${siteSettings.contact.phone.replace(/[^\d+]/g, '')}`}>{siteSettings.contact.phone}</a></p>
                </div>
              </div>
              <div class="contact-item">
                <span class="contact-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </span>
                <div>
                  <strong>E-Posta</strong>
                  <p><a href={`mailto:${siteSettings.contact.email}`}>{siteSettings.contact.email}</a></p>
                </div>
              </div>
              <div class="contact-item">
                <span class="contact-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <div>
                  <strong>Çalışma Saatleri</strong>
                  <p>{siteSettings.contact.workingHours}</p>
                </div>
              </div>
            </address>

            <!-- Social Media -->
            <div class="social-links" aria-label="Sosyal medya bağlantıları">
              <a href="https://www.instagram.com/aryasanatakademisi" class="social-link" id="instagramLink" aria-label="Instagram hesabımızı takip edin">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                Instagram
              </a>
              <a href="#" class="social-link" id="facebookLink" aria-label="Facebook sayfamızı beğenin">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                Facebook
              </a>
              <a href="#" class="social-link" id="youtubeLink" aria-label="YouTube kanalımıza abone olun">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.54C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon></svg>
                YouTube
              </a>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="contact-form-wrapper">
            <form class="contact-form" id="contactForm" novalidate aria-label="Kayıt ve iletişim formu">
              <h3 class="form-title">Ücretsiz Deneme Dersi</h3>
              <p class="form-subtitle">Formu doldurun, size 24 saat içinde ulaşalım.</p>

              <div class="form-group">
                <label for="fullName" class="form-label">Ad Soyad</label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  class="form-input"
                  placeholder="Ad Soyadınız"
                  required
                  autocomplete="name"
                  aria-required="true"
                />
              </div>

              <div class="form-group">
                <label for="phone" class="form-label">Telefon</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-input"
                  placeholder="05XX XXX XX XX"
                  required
                  autocomplete="tel"
                  aria-required="true"
                />
              </div>

              <div class="form-group">
                <label for="email" class="form-label">E-Posta</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="ornek@email.com"
                  autocomplete="email"
                />
              </div>

              <div class="form-group">
                <label for="instrument" class="form-label">İlgilendiğiniz Enstrüman</label>
                <select id="instrument" name="instrument" class="form-input form-select" required aria-required="true">
                  <option value="" disabled selected>Enstrüman Seçiniz</option>
                  <option value="bateri">Bateri</option>
                  <option value="gitar">Gitar</option>
                  <option value="piyano">Piyano</option>
                  <option value="keman">Keman</option>
                  <option value="flut">Yan Flüt</option>
                  <option value="klarnet">Klarnet</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message" class="form-label">Mesajınız (İsteğe Bağlı)</label>
                <textarea
                  id="message"
                  name="message"
                  class="form-input form-textarea"
                  placeholder="Müzik geçmişiniz, hedefleriniz veya sorularınız..."
                  rows="4"
                  aria-multiline="true"
                ></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-full" id="submitBtn">
                Ücretsiz Ders Talep Et
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>

              <div class="form-success" id="formSuccess" role="alert" aria-live="polite" hidden>
                <span aria-hidden="true">✅</span> Talebiniz alındı! En kısa sürede sizinle iletişime geçeceğiz.
              </div>
            </form>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
