  window.selectLessonDay = function(day) {
    document.getElementById('erp-new-lesson-day').value = day;
    document.querySelectorAll('.day-chip-btn').forEach(btn => btn.classList.remove('selected'));
    document.getElementById(`day-chip-${day}`).classList.add('selected');
  };

  window.selectLessonTime = function(time) {
    document.getElementById('erp-new-lesson-time').value = time;
    document.querySelectorAll('.time-slot-btn').forEach(btn => btn.classList.remove('selected'));
    const safeId = `time-slot-${time.replace(/\s+/g, '')}`;
    document.getElementById(safeId).classList.add('selected');
  };

  window.togglePaymentStatus = async function(id) {
    const student = erpDataObj.students.find(s => s.id === id);
    if (student) {
      if (!student.payments) student.payments = {};
      const current = student.payments[erpActiveMonth] || 'Unpaid';
      student.payments[erpActiveMonth] = current === 'Paid' ? 'Unpaid' : 'Paid';
      await saveErpData();
    }
  };

  window.incrementAttendance = async function(id) {
    const student = erpDataObj.students.find(s => s.id === id);
    if (student) {
      if (!student.attendance) student.attendance = {};
      if (!student.attendance[erpActiveMonth]) {
        student.attendance[erpActiveMonth] = { attended: 0, total: 4 };
      }
      const att = student.attendance[erpActiveMonth];
      if (att.attended < att.total) {
        att.attended++;
        await saveErpData();
      }
    }
  };

  window.decrementAttendance = async function(id) {
    const student = erpDataObj.students.find(s => s.id === id);
    if (student) {
      if (!student.attendance) student.attendance = {};
      if (!student.attendance[erpActiveMonth]) {
        student.attendance[erpActiveMonth] = { attended: 0, total: 4 };
      }
      const att = student.attendance[erpActiveMonth];
      if (att.attended > 0) {
        att.attended--;
        await saveErpData();
      }
    }
  };

  window.addNewTeacher = async function() {
    const name = document.getElementById('erp-new-teacher-name').value.trim();
    const specialty = document.getElementById('erp-new-teacher-spec').value.trim();
    const hourlyRate = parseInt(document.getElementById('erp-new-teacher-rate').value) || 300;
    const password = document.getElementById('erp-new-teacher-password').value.trim();

    if (!name || !specialty || !password) {
      alert('Lütfen eğitmen adı, branş ve giriş şifresi alanlarını doldurunuz.');
      return;
    }

    if (!erpDataObj.teachers) erpDataObj.teachers = [];
    
    // Check if passcode already exists
    if (erpDataObj.teachers.some(t => t.password === password)) {
      alert('Bu giriş şifresi başka bir eğitmen tarafından kullanılıyor. Lütfen benzersiz bir şifre seçin.');
      return;
    }

    erpDataObj.teachers.push({
      id: 't_' + Date.now(),
      name,
      specialty,
      hourlyRate,
      password
    });

    document.getElementById('erp-new-teacher-name').value = '';
    document.getElementById('erp-new-teacher-spec').value = '';
    document.getElementById('erp-new-teacher-rate').value = '300';
    document.getElementById('erp-new-teacher-password').value = '';

    await saveErpData();
  };

  window.deleteTeacher = async function(idx) {
    const teacher = erpDataObj.teachers[idx];
    if (teacher) {
      if (confirm(`"${teacher.name}" isimli eğitmeni silmek istediğinize emin misiniz?`)) {
        erpDataObj.teachers.splice(idx, 1);
        await saveErpData();
      }
    }
  };

  window.toggleStudentDetails = function(id) {
    const row = document.getElementById(`erp-details-row-${id}`);
    if (row) {
      row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
    }
  };

  window.saveStudentProgress = async function(id) {
    const student = erpDataObj.students.find(s => s.id === id);
    if (student) {
      const notes = document.getElementById(`erp-student-notes-${id}`).value;
      const progress = parseInt(document.getElementById(`erp-student-progress-${id}`).value) || 0;

      if (!student.notes) student.notes = {};
      if (!student.progress) student.progress = {};

      student.notes[erpActiveMonth] = notes;
      student.progress[erpActiveMonth] = progress;

      await saveErpData();
    }
  };

  window.deleteStudent = async function(id) {
    const idx = erpDataObj.students.findIndex(s => s.id === id);
    if (idx !== -1) {
      const student = erpDataObj.students[idx];
      if (confirm(`"${student.name}" isimli öğrenciyi arşive taşımak istiyor musunuz? Geçmiş ödeme ve katılım bilgileri saklanacaktır.`)) {
        if (!erpDataObj.archivedStudents) erpDataObj.archivedStudents = [];
        erpDataObj.archivedStudents.push(student);
        erpDataObj.students.splice(idx, 1);
        await saveErpData();
      }
    }
  };

  window.restoreStudent = async function(id) {
    const idx = erpDataObj.archivedStudents.findIndex(s => s.id === id);
    if (idx !== -1) {
      const student = erpDataObj.archivedStudents[idx];
      if (confirm(`"${student.name}" isimli öğrenciyi aktif öğrenci listesine geri taşımak istiyor musunuz?`)) {
        erpDataObj.students.push(student);
        erpDataObj.archivedStudents.splice(idx, 1);
        await saveErpData();
      }
    }
  };

  window.deleteArchivedStudent = async function(id) {
    const idx = erpDataObj.archivedStudents.findIndex(s => s.id === id);
    if (idx !== -1) {
      const student = erpDataObj.archivedStudents[idx];
      if (confirm(`"${student.name}" isimli öğrenciyi arşivden tamamen silmek istediğinize emin misiniz? Bu işlem geri alınamaz.`)) {
        erpDataObj.archivedStudents.splice(idx, 1);
        await saveErpData();
      }
    }
  };

  window.deleteLesson = async function(id) {
    const idx = erpDataObj.lessons.findIndex(l => l.id === id);
    if (idx !== -1) {
      if (confirm('Bu dersi programdan kaldırmak istediğinize emin misiniz?')) {
        erpDataObj.lessons.splice(idx, 1);
        await saveErpData();
      }
    }
  };

  async function saveErpData() {
    renderErpDashboard();
    try {
      localStorage.setItem('arya_erp_data', JSON.stringify(erpDataObj));
    } catch (e) {
      console.error('Local cache save error:', e);
    }
    try {
      const response = await fetch('/api/save-erp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ erpData: erpDataObj })
      });
      const data = await response.json();
      if (!response.ok || !data.success) {
        console.error('ERP Save Error:', data.error);
      }
    } catch (err) {
      console.error('ERP Save Network Error:', err);
    }
  }

  window.createNewCourse = function() {
    const slug = prompt('Lütfen eklenecek yeni kurs için bir URL uzantısı (slug) giriniz:\n(Yalnızca küçük İngilizce harfler, rakamlar ve tire kullanın. Örn: keman-egitimi, saksafon)');
    if (!slug) return;
    
    const cleanSlug = slug.toLowerCase().trim().replace(/[^a-z0-9\-]/g, '');
    if (!cleanSlug) {
      alert('Geçersiz URL uzantısı! Yalnızca İngilizce harfler, rakamlar ve tire kullanabilirsiniz.');
      return;
    }
    
    window.location.href = `/admin/edit?course=${cleanSlug}`;
  };

