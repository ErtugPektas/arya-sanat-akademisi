        if (tagEl) tagEl.value = settings.whyUs.tag || '';
        const titleEl = document.querySelector('input[name="why_title"]');
        if (titleEl) titleEl.value = settings.whyUs.title || '';
        const descEl = document.querySelector('textarea[name="why_desc"]');
        if (descEl) descEl.value = settings.whyUs.desc || '';
        
        // Re-render features card blocks dynamically from cache!
        if (settings.whyUs && Array.isArray(settings.whyUs.features)) {
          const container = document.getElementById('whyus-cards-container');
          if (container) {
