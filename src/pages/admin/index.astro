                  </div>
                  <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <label style="font-weight: 500; font-size: 0.85rem; color: #b4b4c6;">E-posta Adresi</label>
                    <input type="email" name="contact_email" value={siteSettings.contact.email} required style="background: #161622; border: 1px solid #1f1f2e; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; font-size: 0.9rem; outline: none;" />
                  </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
