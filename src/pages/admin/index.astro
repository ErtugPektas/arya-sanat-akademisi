              div.innerHTML = `
                <button type="button" onclick="this.closest('.whyus-card-block').remove()" style="position: absolute; top: 12px; right: 12px; background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); padding: 0.35rem 0.65rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">Kartı Kaldır 🗑️</button>
                <strong style="color: #fff; font-size: 0.9rem;">Özellik Kartı</strong>
                <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Kart Başlığı</label>
                  <input type="text" class="whyus-card-title" value="${feat.title || ''}" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem;" />
                </div>
                <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Kart Açıklaması</label>
                  <textarea class="whyus-card-desc" rows="2" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; resize: vertical; font-family: sans-serif;">${feat.desc || ''}</textarea>
                </div>
                <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Kart Özellikleri (Virgülle Ayırın)</label>
                  <input type="text" class="whyus-card-items" value="${feat.items || ''}" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem;" />
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Kart Görseli (Opsiyonel)</label>
                    <div style="display: flex; gap: 0.5rem;">
                      <input type="text" id="whyus-card-img-path-${index}" class="whyus-card-image" value="${feat.image || ''}" style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; width: 100%;" oninput="document.getElementById('whyus-card-img-prev-${index}').src = this.value" />
                      <button type="button" onclick="document.getElementById('whyus-card-img-file-${index}').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Seç 📁</button>
                      <input type="file" id="whyus-card-img-file-${index}" style="display: none;" accept="image/*" onchange="uploadFile(this, 'whyus-card-img-path-${index}', 'whyus-card-img-prev-${index}')" />
