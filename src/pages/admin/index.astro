<script is:inline define:vars={{ initialAnnouncements: duyurular, initialErpData: erpData, userRole: role, activeTeacher: activeTeacherName }}>
  async function compressImageIfNeeded(file) {
    if (!file || !file.type || !file.type.startsWith('image/') || file.size < 800000) {
      return file;
    }
    return new Promise((resolve) => {
      const img = new Image();
      const reader = new FileReader();
      reader.onload = (e) => {
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          const maxDim = 1200;
          if (width > maxDim || height > maxDim) {
            if (width > height) {
              height = Math.round((height * maxDim) / width);
              width = maxDim;
            } else {
              width = Math.round((width * maxDim) / height);
              height = maxDim;
            }
          }
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          canvas.toBlob((blob) => {
            if (blob) {
              resolve(new File([blob], file.name.replace(/\.[^/.]+$/, "") + ".jpg", { type: 'image/jpeg' }));
            } else {
              resolve(file);
            }
          }, 'image/jpeg', 0.8);
        };
        img.onerror = () => resolve(file);
        img.src = e.target.result;
      };
      reader.onerror = () => resolve(file);
      reader.readAsDataURL(file);
    });
  }

  async function safeFetchJson(url, options) {
    try {
      const response = await fetch(url, options);
      const text = await response.text();
      let data = {};
      try {
        data = JSON.parse(text);
      } catch (e) {
        if (response.status === 413 || text.includes('Request Entity Too Large') || text.includes('Too Large')) {
          return { ok: false, error: 'Yüklenen içerik/görsel boyutu Vercel sınırını aşıyor (Max 4.5MB). Lütfen daha küçük görseller kullanınız.' };
        }
        return { ok: false, error: `Sunucu Yanıt Hatası (${response.status}): ${text.substring(0, 100)}` };
      }
      return { ok: response.ok, status: response.status, ...data };
    } catch (err) {
      return { ok: false, error: err.message || 'Ağ bağlantı hatası' };
    }
  }

  async function uploadFile(inputEl, textInputId, previewImgId) {
    if (!inputEl.files || !inputEl.files[0]) return;
    
    const originalFile = inputEl.files[0];
    const btn = inputEl.previousElementSibling;
    const originalText = btn ? btn.innerText : 'Yükle';
    if (btn) {
      btn.disabled = true;
      btn.innerText = 'Sıkıştırılıyor... ⏳';
    }
    
    const file = await compressImageIfNeeded(originalFile);
    if (btn) btn.innerText = 'Yükleniyor... ⏳';
    
    const setUploadedUrl = (url) => {
      const inputTarget = document.getElementById(textInputId);
      if (inputTarget) inputTarget.value = url;
      const previewEl = document.getElementById(previewImgId);
      if (previewEl) {
        previewEl.src = url;
        if (previewEl.tagName === 'VIDEO') {
          previewEl.style.display = 'block';
          previewEl.load();
          previewEl.play().catch(e => console.log('Autoplay check:', e));
        } else {
          previewEl.style.display = 'block';
        }
      }
      alert('✓ Görsel / Medya başarıyla yüklendi ve eklendi!');
    };

    try {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch('/api/upload-image', {
        method: 'POST',
        body: formData
      });
      
      const responseText = await response.text();
      let result = {};
      try {
        result = JSON.parse(responseText);
      } catch(e) {
        if (response.status === 413 || responseText.includes('Too Large')) {
          alert('❌ Yüklenen görsel boyutu çok büyük (Max 4.5MB). Lütfen daha küçük bir resim seçiniz.');
          return;
        }
      }
      
      if (response.ok && result.success && result.url) {
        setUploadedUrl(result.url);
      } else {
        const reader = new FileReader();
        reader.onload = (e) => setUploadedUrl(e.target.result);
        reader.readAsDataURL(file);
      }
    } catch (err) {
      const reader = new FileReader();
      reader.onload = (e) => setUploadedUrl(e.target.result);
      reader.readAsDataURL(file);
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.innerText = originalText;
      }
      inputEl.value = '';
    }
  }
  
  window.uploadFile = uploadFile;

  function syncInputsFromCache() {
    try {
      const cached = localStorage.getItem('admin_site_settings_cache');
      if (!cached) return;
      
      const settings = JSON.parse(cached);
      
      // Populate SEO
      if (settings.seo) {
        const titleEl = document.querySelector('input[name="seo_title"]');
        if (titleEl) titleEl.value = settings.seo.title || '';
        const descEl = document.querySelector('textarea[name="seo_desc"]');
        if (descEl) descEl.value = settings.seo.description || '';
      }
      
      // Populate Contact
      if (settings.contact) {
        document.querySelectorAll('[name^="contact_"]').forEach(el => {
          const key = el.name.replace('contact_', '');
          if (settings.contact[key] !== undefined) {
            el.value = settings.contact[key];
          }
        });
      }
      
      // Populate Stats
      if (settings.stats) {
        document.querySelectorAll('[name^="stats_"]').forEach(el => {
          const key = el.name.replace('stats_', '');
          const mappedKey = key === 'cert' ? 'certification' :
                            key === 'loc' ? 'location' :
                            key === 'students' ? 'studentsCount' :
                            key === 'teachers' ? 'teachersCount' :
                            key === 'exp' ? 'experienceYears' : key;
          if (settings.stats[mappedKey] !== undefined) {
            el.value = settings.stats[mappedKey];
          }
        });
