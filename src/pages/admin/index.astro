        </div>
        <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Branşı / Uzmanlığı</label>
          <input type="text" class="teacher-block-specialty" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem;" placeholder="Örn: Bateri Eğitmeni" />
        </div>
      </div>

      <div style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
        <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1; min-width: 250px;">
          <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Eğitmen Görsel Yolu</label>
          <div style="display: flex; gap: 0.5rem;">
            <input type="text" id="teacher-img-path-${index}" class="teacher-block-image" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; width: 100%;" oninput="document.getElementById('teacher-img-prev-${index}').src = this.value" placeholder="/assets/teachers/default.jpg" />
            <button type="button" onclick="document.getElementById('teacher-img-file-${index}').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Görsel Yükle 📁</button>
            <input type="file" id="teacher-img-file-${index}" style="display: none;" accept="image/*" onchange="uploadFile(this, 'teacher-img-path-${index}', 'teacher-img-prev-${index}')" />
          </div>
        </div>
        <div style="width: 60px; height: 60px; border-radius: 50%; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <img id="teacher-img-prev-${index}" src="/assets/teachers/default.jpg" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>

      <div style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
        <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1; min-width: 250px;">
          <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Video Önizlemesi (MP4 - Opsiyonel)</label>
          <div style="display: flex; gap: 0.5rem;">
            <input type="text" id="teacher-video-path-${index}" class="teacher-block-video" style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; width: 100%;" oninput="document.getElementById('teacher-video-prev-${index}').src = this.value" placeholder="/assets/teachers/video.mp4" />
            <button type="button" onclick="document.getElementById('teacher-video-file-${index}').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Video Yükle 📁</button>
            <input type="file" id="teacher-video-file-${index}" style="display: none;" accept="video/*" onchange="uploadFile(this, 'teacher-video-path-${index}', 'teacher-video-prev-${index}')" />
          </div>
        </div>
        <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <video id="teacher-video-prev-${index}" src="" loop muted autoplay style="width: 100%; height: 100%; object-fit: cover; display: none;" onerror="this.style.display='none'" onloadeddata="this.style.display='block'"></video>
        </div>
      </div>

      <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Kısa Özgeçmiş / Biyografi</label>
        <textarea class="teacher-block-bio1" rows="2" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; resize: vertical; font-family: sans-serif;" placeholder="Eğitmen biyografisi..."></textarea>
      </div>

      <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Uzmanlık Etiketleri (Virgülle Ayırın)</label>
        <input type="text" class="teacher-block-tags" required style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem;" placeholder="Örn: Pop, Rock, Teori" />
      </div>
    `;
    container.appendChild(div);
  };

  const btnAddGalleryImg = document.getElementById('btn-add-gallery-img');
  if (btnAddGalleryImg) {
    btnAddGalleryImg.addEventListener('click', () => {
      const container = document.getElementById('gallery-images-container');
      if (!container) return;
      
      const index = container.children.length + 100;
      const div = document.createElement('div');
      div.className = 'gallery-image-block';
      div.style.cssText = 'background: #161622; border: 1px solid #1f1f2e; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem; position: relative;';
      
      div.innerHTML = `
        <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-weight: 500; font-size: 0.8rem; color: #b4b4c6;">Görsel Yolu</label>
          <div style="display: flex; gap: 0.5rem;">
            <input type="text" id="gallery-img-path-${index}" class="gallery-image-path" style="background: #101016; border: 1px solid #1f1f2e; color: #fff; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.875rem; width: 100%;" oninput="document.getElementById('gallery-img-prev-${index}').src = this.value" placeholder="/assets/gallery/resim.jpg" />
            <button type="button" onclick="document.getElementById('gallery-img-file-${index}').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.55rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Görsel Yükle 📁</button>
            <input type="file" id="gallery-img-file-${index}" style="display: none;" accept="image/*" onchange="uploadFile(this, 'gallery-img-path-${index}', 'gallery-img-prev-${index}')" />
          </div>
        </div>
        <div style="width: 70px; height: 50px; border-radius: 6px; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <img id="gallery-img-prev-${index}" src="/assets/teachers/default.jpg" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <button type="button" onclick="this.closest('.gallery-image-block').remove()" style="background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); padding: 0.35rem 0.65rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; cursor: pointer; margin-left: 0.5rem;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">🗑️</button>
      `;
      container.appendChild(div);
    });
  }

  // SITE SETTINGS SAVE CONTROLLER
  const btnSaveSettings = document.getElementById('btn-save-settings');
  const formSettings = document.getElementById('settings-form');

  if (btnSaveSettings && formSettings) {
    btnSaveSettings.addEventListener('click', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(formSettings);
      
      const settings = {
        seo: {
          title: formData.get('seo_title'),
          description: formData.get('seo_desc')
        },
        contact: {
          phone: formData.get('contact_phone'),
          email: formData.get('contact_email'),
          address: formData.get('contact_address'),
          workingHours: formData.get('contact_hours'),
          whatsapp: formData.get('contact_whatsapp')
        },
        stats: {
          certification: formData.get('stats_cert'),
          location: formData.get('stats_loc'),
          studentsCount: formData.get('stats_students'),
          teachersCount: formData.get('stats_teachers'),
          experienceYears: formData.get('stats_exp')
        },
        hero: {
          tag: formData.get('hero_tag'),
          title: formData.get('hero_title'),
          titleHighlight: formData.get('hero_highlight'),
          desc: formData.get('hero_desc')
        },
        whyUs: {
          tag: formData.get('why_tag'),
          title: formData.get('why_title'),
          desc: formData.get('why_desc'),
          features: Array.from(document.querySelectorAll('.whyus-card-block')).map((block, index) => {
            return {
              id: `feature-${index}`,
              title: block.querySelector('.whyus-card-title').value,
              desc: block.querySelector('.whyus-card-desc').value,
              items: block.querySelector('.whyus-card-items').value,
              image: block.querySelector('.whyus-card-image').value,
              videoPreview: block.querySelector('.whyus-card-video').value
            };
          })
        },
        teachersSection: {
          tag: formData.get('teachers_tag'),
          title: formData.get('teachers_title'),
          desc: formData.get('teachers_desc'),
          list: Array.from(document.querySelectorAll('.teacher-block-item')).map(block => {
            return {
              name: block.querySelector('.teacher-block-name').value,
              specialty: block.querySelector('.teacher-block-specialty').value,
              image: block.querySelector('.teacher-block-image').value,
              videoPreview: block.querySelector('.teacher-block-video').value,
              bio1: block.querySelector('.teacher-block-bio1').value,
              tags: block.querySelector('.teacher-block-tags').value.split(',').map(t => t.trim()).filter(Boolean)
            };
          })
        },
        gallery: {
          title: formData.get('gallery_title'),
          desc: formData.get('gallery_desc'),
          images: Array.from(document.querySelectorAll('.gallery-image-path')).map(input => input.value).filter(Boolean)
        },
        navbar: {
          ctaText: formData.get('nav_cta_text'),
          links: Array.from(document.querySelectorAll('.navbar-link-block')).map(block => {
            return {
              text: block.querySelector('.navbar-link-text').value,
              url: block.querySelector('.navbar-link-url').value
            };
          })
        }
      };

      btnSaveSettings.disabled = true;
      btnSaveSettings.innerText = 'Kaydediliyor... ⏳';

      try {
        const result = await safeFetchJson('/api/save-settings', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ settings })
        });
        
        if (result.ok && result.success) {
          localStorage.setItem('admin_site_settings_cache', JSON.stringify(settings));
          alert(result.local 
            ? '✓ Ayarlar yerel diske başarıyla kaydedildi!' 
            : '✓ Ayarlar başarıyla kaydedildi! Vercel derlemesi başlatıldı, güncellenmesi ~1 dakika sürecektir.'
          );
          location.reload();
        } else {
          alert('❌ Hata oluştu: ' + (result.error || 'Bilinmeyen hata'));
        }
      } catch (err) {
        alert('❌ Kaydetme hatası: ' + err.message);
      } finally {
        btnSaveSettings.disabled = false;
        btnSaveSettings.innerText = 'Ayarları Kaydet 💾';
      }
    });
  }
</script>
