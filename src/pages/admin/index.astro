---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import duyurular from '../../content/duyurular.json';

export const prerender = false;

let errorMsg = '';
const adminPassword = process.env.ADMIN_PASSWORD || 'arya2026';

// Check logout
const url = new URL(Astro.request.url);
if (url.searchParams.get('action') === 'logout') {
  Astro.cookies.delete('admin_session', { path: '/' });
  return Astro.redirect('/admin');
}

// Handle login post
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const password = data.get('password');
    
    if (password === adminPassword) {
      Astro.cookies.set('admin_session', 'true', { path: '/', maxAge: 86400, httpOnly: true, sameSite: 'strict' });
      return Astro.redirect('/admin');
    } else {
      errorMsg = 'Geçersiz şifre, lütfen tekrar deneyin.';
    }
  } catch (e) {
    errorMsg = 'Bir hata oluştu.';
  }
}

// Check session
const isLoggedIn = Astro.cookies.has('admin_session') && Astro.cookies.get('admin_session').value === 'true';

let courses = [];
if (isLoggedIn) {
  courses = await getCollection('kurslar');
}
---

<Layout title="Yönetim Paneli | Arya Sanat Akademisi" description="Arya Sanat Akademisi Yönetim Paneli">
  <link rel="stylesheet" href="/css/style.css" slot="head" />
  
  <div class="admin-container" style="min-height: 100vh; padding: 0 0 4rem 0; background: #07070a; color: #fff; font-family: sans-serif;">
    
    <!-- CUSTOM ADMIN TOPBAR -->
    {isLoggedIn && (
      <div style="background: #101016; border-bottom: 1px solid #1f1f2e; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <span style="font-size: 1.5rem; color: #d4af37;">♩</span>
          <div>
            <strong style="color: #fff; font-size: 1.05rem; display: block; font-weight: 700;">Arya Sanat</strong>
            <span style="color: #d4af37; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">Yönetim Paneli</span>
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: 1.5rem;">
          <a href="/" target="_blank" style="color: #b4b4c6; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#b4b4c6'"> Canlı Siteyi Gör 🌐</a>
          <a 
            href="/admin?action=logout" 
            style="background: rgba(239, 68, 68, 0.12); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.25); padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
            onmouseover="this.style.background='rgba(239, 68, 68, 0.2)'; this.style.borderColor='rgba(239,68,68,0.4)';"
            onmouseout="this.style.background='rgba(239, 68, 68, 0.12)'; this.style.borderColor='rgba(239,68,68,0.25)';"
          >
            Güvenli Çıkış 🚪
          </a>
        </div>
      </div>
    )}

    <div style="max-width: 1000px; margin: 0 auto; padding: 3rem 1.5rem;">
      
      {!isLoggedIn ? (
        // PREMIUM LOGIN FORM
        <div style="max-width: 420px; margin: 4rem auto; background: #101016; padding: 3rem 2.5rem; border-radius: 16px; border: 1px solid #1f1f2e; box-shadow: 0 20px 50px rgba(0,0,0,0.6); position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #d4af37, #f5a623);"></div>
          
          <div style="text-align: center; margin-bottom: 2.5rem;">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border-radius: 50%; background: rgba(212,175,55,0.08); border: 1px solid rgba(212,175,55,0.15); margin-bottom: 1rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 8px rgba(212,175,55,0.35));"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <h1 style="font-size: 1.75rem; margin-top: 1.25rem; color: #fff; font-weight: 800; letter-spacing: -0.02em;">Yönetici Girişi</h1>
            <p style="color: #8b8b9f; font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.5;">İçerikleri düzenlemek ve web sitesini güncellemek için şifrenizi girin</p>
          </div>
          
          {errorMsg && (
            <div style="background: rgba(239, 68, 68, 0.12); border: 1px solid #ef4444; color: #fca5a5; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 2rem; font-size: 0.85rem; text-align: center; font-weight: 500;">
              ⚠️ {errorMsg}
            </div>
          )}
          
          <form method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label for="password" style="font-size: 0.8rem; color: #a4a4b6; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">Giriş Şifresi</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                required 
                style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.9rem 1.1rem; border-radius: 8px; font-size: 1rem; outline: none; transition: border-color 0.2s;"
                placeholder="••••••••"
              />
            </div>
            
            <button 
              type="submit" 
              style="background: linear-gradient(135deg, #d4af37 0%, #aa841c 100%); color: #000; border: none; padding: 1rem; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(212,175,55,0.25);"
              onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(212,175,55,0.4)';"
              onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(212,175,55,0.25)';"
            >
              Giriş Yap
            </button>
          </form>
        </div>
      ) : (
        // DASHBOARD WITH LAYERED GRID, STATS & ANALYTICS TABS
        <div>
          
          <!-- Welcome Bar -->
          <div style="margin-bottom: 2rem;">
            <h1 style="font-size: 2.2rem; font-weight: 800; color: #fff; margin: 0; letter-spacing: -0.02em;">Yönetim Masası</h1>
            <p style="color: #8b8b9f; margin-top: 0.5rem; font-size: 1rem;">Arya Sanat Akademisi web sitesi içerik yönetim alanı</p>
          </div>

          <!-- TABS SYSTEM -->
          <div style="display: flex; gap: 1rem; border-bottom: 1px solid #1f1f2e; padding-bottom: 1rem; margin-bottom: 2.5rem; overflow-x: auto;">
            <button 
              id="tab-courses" 
              style="background: #1c1c28; color: #d4af37; border: 1px solid #d4af37; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              <span>Kurs Yönetimi</span>
            </button>
            <button 
              id="tab-announcements" 
              style="background: #101016; color: #b4b4c6; border: 1px solid #1f1f2e; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
              <span>Duyuru &amp; Kampanyalar</span>
            </button>
            <button 
              id="tab-analytics" 
              style="background: #101016; color: #b4b4c6; border: 1px solid #1f1f2e; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
              <span>Trafik Analitiği</span>
            </button>
          </div>

          <!-- SECTION 1: COURSES (VISIBLE BY DEFAULT) -->
          <div id="sec-courses" style="display: block;">
            <!-- Katmanlı Özet Paneli (Stats Grid) -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 3.5rem;">
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(212,175,55,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #d4af37; border: 1px solid rgba(212,175,55,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Aktif Programlar</span>
                  <strong style="color: #fff; font-size: 1.4rem; display: block; margin-top: 0.25rem;">{courses.length} Kurs</strong>
                </div>
              </div>
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(16,185,129,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #10b981; border: 1px solid rgba(16,185,129,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Sertifikasyon</span>
                  <strong style="color: #fff; font-size: 1.4rem; display: block; margin-top: 0.25rem;">MEB Onaylı</strong>
                </div>
              </div>
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(30,144,255,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #1e90ff; border: 1px solid rgba(30,144,255,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Konum Detayı</span>
                  <strong style="color: #fff; font-size: 1.4rem; display: block; margin-top: 0.25rem;">Kocasinan</strong>
                </div>
              </div>
            </div>

            <!-- Section Title -->
            <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 2rem; color: #d4af37; display: flex; align-items: center; gap: 0.75rem; border-bottom: 1px solid #1f1f2e; padding-bottom: 0.75rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color: #d4af37;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              <span>Kurs Detay Sayfaları</span>
              <span style="font-size: 0.85rem; font-weight: 500; color: #8b8b9f; background: #1c1c28; padding: 0.2rem 0.6rem; border-radius: 12px; margin-left: auto;">{courses.length} Toplam</span>
            </h2>

            <!-- Course Cards Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
              {courses.map((course) => (
                <div class="admin-course-card" style="background: #101016; border: 1px solid #1f1f2e; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                  <div style="height: 180px; overflow: hidden; position: relative;">
                    <img 
                      src={course.data.image} 
                      alt={course.data.heroTitle} 
                      style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;"
                    />
                    <div style="position: absolute; top: 12px; left: 12px; background: rgba(7,7,10,0.85); border: 1px solid rgba(212,175,55,0.3); padding: 0.35rem 0.75rem; border-radius: 20px; font-size: 0.8rem; color: #d4af37; font-weight: 600;">
                      {course.data.badge}
                    </div>
                  </div>
                  
                  <div style="padding: 1.75rem; display: flex; flex-direction: column; flex-grow: 1; gap: 1.25rem;">
                    <div>
                      <h3 style="font-size: 1.3rem; font-weight: 700; margin: 0; color: #fff; letter-spacing: -0.01em;">{course.data.heroTitle}</h3>
                      <p style="color: #8b8b9f; font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        {course.data.description}
                      </p>
                    </div>
                    
                    <div style="background: #161622; border-radius: 8px; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: #b4b4c6; border: 1px solid #1f1f2e;">
                      <div style="display:flex; justify-content:space-between;"><span>⏱️ Süre:</span> <strong style="color:#fff;">{course.data.duration}</strong></div>
                      <div style="display:flex; justify-content:space-between;"><span>📅 Sıklık:</span> <strong style="color:#fff;">{course.data.frequency}</strong></div>
                      <div style="display:flex; justify-content:space-between;"><span>👨‍🏫 Eğitmen:</span> <strong style="color:#fff;">{course.data.teacher.name}</strong></div>
                    </div>
                    
                    <a 
                      href={`/admin/edit?course=${course.id}`}
                      style="display: block; text-align: center; background: #1c1c28; color: #fff; border: 1px solid #232335; padding: 0.85rem; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.25s; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                      onmouseover="this.style.background='#d4af37'; this.style.color='#000'; this.style.borderColor='#d4af37'; this.style.boxShadow='0 4px 12px rgba(212,175,55,0.3)';"
                      onmouseout="this.style.background='#1c1c28'; this.style.color='#fff'; this.style.borderColor='#232335'; this.style.boxShadow='none';"
                    >
                      Sayfayı Düzenle ✏️
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- SECTION 2: ANNOUNCEMENTS & CAMPAIGNS (HIDDEN BY DEFAULT) -->
          <div id="sec-announcements" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1f1f2e; padding-bottom: 1rem; margin-bottom: 2rem;">
              <h2 style="font-size: 1.4rem; font-weight: 700; color: #d4af37; display: flex; align-items: center; gap: 0.5rem; margin: 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                <span>Duyuru &amp; Kampanya Yönetimi</span>
              </h2>
              <button 
                id="btn-add-announcement" 
                style="background: #1c1c28; color: #fff; border: 1px solid #232335; padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.2s;"
                onmouseover="this.style.background='#222230'" 
                onmouseout="this.style.background='#1c1c28'"
              >
                + Yeni Duyuru Ekle
              </button>
            </div>
            
            <div id="announcements-editor-list" style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 3rem;">
              <!-- Dynamically populated via JS -->
            </div>
            
            <div style="border-top: 1px solid #1f1f2e; padding-top: 2rem; display: flex; justify-content: flex-end;">
              <button 
                id="btn-save-announcements" 
                style="background: linear-gradient(135deg, #d4af37 0%, #aa841c 100%); color: #000; border: none; padding: 0.9rem 2rem; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(212,175,55,0.25); transition: all 0.2s;"
                onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(212,175,55,0.4)';" 
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(212,175,55,0.25)';"
              >
                Değişiklikleri Kaydet ve Yayınla 🚀
              </button>
            </div>
          </div>

          <!-- SECTION 3: ANALYTICS (HIDDEN BY DEFAULT) -->
          <div id="sec-analytics" style="display: none;">
            
            <!-- Connection Status -->
            <div style="display: flex; flex-direction: column; background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; gap: 1rem;">
              <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                <span style="font-size: 0.9rem; color: #8b8b9f; font-weight: 600;">Veri İzleme Durumu:</span>
                <span id="kv-status-badge" style="padding: 0.35rem 0.85rem; border-radius: 20px; font-size: 0.8rem; font-weight: 700; border: 1px solid #232335; color: #b4b4c6;">Yükleniyor...</span>
              </div>
              <div id="diagnostics-panel" style="padding-top: 1rem; border-top: 1px solid #1f1f2e; font-size: 0.825rem; line-height: 1.6; color: #b4b4c6; display: none;"></div>
            </div>

            <!-- KV Activation Instructions -->
            <div id="kv-instructions" style="display: none; background: rgba(245,166,35,0.06); border: 1px solid rgba(245,166,35,0.2); padding: 1.5rem; border-radius: 12px; margin-bottom: 2.5rem; font-size: 0.875rem; line-height: 1.6; color: #b4b4c6;">
              <strong style="color: #fff; font-size: 0.95rem; display: block; margin-bottom: 0.5rem; color: #f5a623;">💡 Canlı Trafik Analitiğini Etkinleştirin</strong>
              Web siteniz Vercel'e yüklenmiştir. Vercel Dashboard'unuzdaki <strong>Storage</strong> sekmesinden 1 tıkla ücretsiz bir <strong>KV (Redis)</strong> veritabanı oluşturup bu projeye bağlayarak gerçek ziyaretçileri izleyebilirsiniz. Herhangi bir kod yazmanıza gerek yoktur, bağlantı kurulduğunda bu panel otomatik olarak canlı verileri saymaya başlayacaktır.
            </div>

            <!-- Stats Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(212,175,55,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #d4af37; border: 1px solid rgba(212,175,55,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Toplam Gösterim</span>
                  <strong id="stat-total-views" style="color: #fff; font-size: 1.6rem; display: block; margin-top: 0.25rem;">-</strong>
                </div>
              </div>
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(16,185,129,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #10b981; border: 1px solid rgba(16,185,129,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">En Popüler Sayfa</span>
                  <strong id="stat-popular-page" style="color: #d4af37; font-size: 1.15rem; display: block; margin-top: 0.25rem; font-weight: 700; max-width: 190px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">-</strong>
                </div>
              </div>
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
                <span style="background: rgba(30,144,255,0.08); width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #1e90ff; border: 1px solid rgba(30,144,255,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                </span>
                <div>
                  <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Aktif Periyot Trafiği</span>
                  <strong id="stat-today-views" style="color: #fff; font-size: 1.6rem; display: block; margin-top: 0.25rem;">-</strong>
                </div>
              </div>
            </div>

            <!-- Graphs Split Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
              
              <!-- Left Card: Bar Chart of Page Views -->
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 2rem; border-radius: 16px;">
                <h3 style="margin: 0 0 1.5rem 0; font-size: 1.15rem; color: #fff; font-weight: 700; border-bottom: 1px solid #1f1f2e; padding-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #d4af37;"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                  <span>En Çok Tıklanan Sayfalar</span>
                </h3>
                <div id="pageviews-list" style="margin-top: 1.5rem;">
                  <!-- Dynamically populated via JS -->
                </div>
              </div>

              <!-- Right Card: SVG Line Chart of Daily Traffic -->
              <div style="background: #101016; border: 1px solid #1f1f2e; padding: 2rem; border-radius: 16px; display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1f1f2e; padding-bottom: 0.75rem; margin-bottom: 1.5rem;">
                    <h3 style="margin: 0; font-size: 1.15rem; color: #fff; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color: #d4af37;"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                      <span>Trafik Akışı</span>
                    </h3>
                    
                    <!-- PERIOD SELECTOR (Saatlik, Günlük, Aylık) -->
                    <div style="display: flex; background: #161622; padding: 0.2rem; border-radius: 6px; border: 1px solid #1f1f2e; gap: 0.25rem;">
                      <button id="btn-period-hour" style="background: transparent; color: #b4b4c6; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s;">Saatlik</button>
                      <button id="btn-period-day" style="background: #1c1c28; color: #d4af37; border: 1px solid #232335; padding: 0.35rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s;">Günlük</button>
                      <button id="btn-period-month" style="background: transparent; color: #b4b4c6; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s;">Aylık</button>
                    </div>
                  </div>
                  
                  <div style="position: relative; width: 100%; height: 160px; margin-top: 2rem;">
                    <svg id="traffic-svg" viewBox="0 0 500 150" width="100%" height="150" style="overflow: visible;">
                      <defs>
                        <linearGradient id="chart-grad" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#d4af37" stop-opacity="0.3"></stop>
                          <stop offset="100%" stop-color="#d4af37" stop-opacity="0.0"></stop>
                        </linearGradient>
                      </defs>
                      
                      <!-- Grid lines -->
                      <line x1="0" y1="130" x2="500" y2="130" stroke="#1f1f2e" stroke-dasharray="4"></line>
                      <line x1="0" y1="80" x2="500" y2="80" stroke="#1f1f2e" stroke-dasharray="4"></line>
                      <line x1="0" y1="30" x2="500" y2="30" stroke="#1f1f2e" stroke-dasharray="4"></line>
                      
                      <!-- Area under line -->
                      <path id="traffic-area" fill="url(#chart-grad)" d="M 0,130 L 500,130 Z"></path>
                      
                      <!-- Glowing line -->
                      <path id="traffic-line" fill="none" stroke="#d4af37" stroke-width="3.5" d="" style="filter: drop-shadow(0px 4px 8px rgba(212,175,55,0.3));"></path>
                    </svg>
                  </div>
                </div>
                
                <!-- Labels Row -->
                <div id="traffic-labels" style="display: flex; justify-content: space-between; margin-top: 1rem; color: #8b8b9f; font-size: 0.75rem; font-family: monospace; overflow-x: auto; gap: 0.5rem; padding-bottom: 0.25rem;">
                  <!-- Dynamically populated via JS -->
                </div>
              </div>

            </div>

          </div>

        </div>
      )}

    </div>
  </div>
</Layout>

<!-- CLIENT-SIDE TABS AND SVG GRAPH SCHEDULER -->
<script is:inline define:vars={{ initialAnnouncements: duyurular }}>
  const tabCourses = document.getElementById('tab-courses');
  const tabAnnouncements = document.getElementById('tab-announcements');
  const tabAnalytics = document.getElementById('tab-analytics');
  
  const secCourses = document.getElementById('sec-courses');
  const secAnnouncements = document.getElementById('sec-announcements');
  const secAnalytics = document.getElementById('sec-analytics');

  let activePeriod = 'day'; // Default period

  if (tabCourses && tabAnnouncements && tabAnalytics && secCourses && secAnnouncements && secAnalytics) {
    tabCourses.addEventListener('click', () => {
      tabCourses.style.background = '#1c1c28';
      tabCourses.style.color = '#d4af37';
      tabCourses.style.borderColor = '#d4af37';
      
      tabAnnouncements.style.background = '#101016';
      tabAnnouncements.style.color = '#b4b4c6';
      tabAnnouncements.style.borderColor = '#1f1f2e';
      
      tabAnalytics.style.background = '#101016';
      tabAnalytics.style.color = '#b4b4c6';
      tabAnalytics.style.borderColor = '#1f1f2e';
      
      secCourses.style.display = 'block';
      secAnnouncements.style.display = 'none';
      secAnalytics.style.display = 'none';
    });

    tabAnnouncements.addEventListener('click', () => {
      tabAnnouncements.style.background = '#1c1c28';
      tabAnnouncements.style.color = '#d4af37';
      tabAnnouncements.style.borderColor = '#d4af37';
      
      tabCourses.style.background = '#101016';
      tabCourses.style.color = '#b4b4c6';
      tabCourses.style.borderColor = '#1f1f2e';
      
      tabAnalytics.style.background = '#101016';
      tabAnalytics.style.color = '#b4b4c6';
      tabAnalytics.style.borderColor = '#1f1f2e';
      
      secCourses.style.display = 'none';
      secAnnouncements.style.display = 'block';
      secAnalytics.style.display = 'none';
      
      renderAnnouncementsList();
    });

    tabAnalytics.addEventListener('click', () => {
      tabAnalytics.style.background = '#1c1c28';
      tabAnalytics.style.color = '#d4af37';
      tabAnalytics.style.borderColor = '#d4af37';
      
      tabCourses.style.background = '#101016';
      tabCourses.style.color = '#b4b4c6';
      tabCourses.style.borderColor = '#1f1f2e';
      
      tabAnnouncements.style.background = '#101016';
      tabAnnouncements.style.color = '#b4b4c6';
      tabAnnouncements.style.borderColor = '#1f1f2e';
      
      secCourses.style.display = 'none';
      secAnnouncements.style.display = 'none';
      secAnalytics.style.display = 'block';
      
      loadAnalytics(activePeriod);
    });
  }

  // ANNOUNCEMENTS MANAGEMENT LOGIC
  let announcementsList = [...initialAnnouncements];
  const listContainer = document.getElementById('announcements-editor-list');

  function renderAnnouncementsList() {
    if (!listContainer) return;
    
    if (announcementsList.length === 0) {
      listContainer.innerHTML = `
        <div style="text-align: center; padding: 4rem 2rem; background: #101016; border: 1px solid #1f1f2e; border-radius: 16px; color: #8b8b9f;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #8b8b9f; margin-bottom: 1rem;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <p style="margin: 0; font-size: 1rem; font-weight: 500;">Henüz eklenmiş bir duyuru veya kampanya bulunmuyor.</p>
        </div>
      `;
      return;
    }
    
    listContainer.innerHTML = announcementsList.map((ann, idx) => `
      <div style="background: #101016; border: 1px solid #1f1f2e; border-radius: 12px; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative;">
        <button onclick="deleteAnnouncement(${idx})" style="position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); padding: 0.45rem 0.9rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">Kaldır 🗑️</button>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 80%;">
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Etiket (Badge)</label>
            <select onchange="updateAnnouncement(${idx}, 'badge', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; cursor: pointer;">
              <option value="Kampanya" ${ann.badge === 'Kampanya' ? 'selected' : ''}>Kampanya 🎁</option>
              <option value="Duyuru" ${ann.badge === 'Duyuru' ? 'selected' : ''}>Duyuru 📢</option>
            </select>
          </div>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Tarih</label>
            <input type="text" value="${ann.date}" oninput="updateAnnouncement(${idx}, 'date', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem;" placeholder="Örn: 15 Temmuz 2026" />
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Başlık</label>
          <input type="text" value="${ann.title}" oninput="updateAnnouncement(${idx}, 'title', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; width: 100%;" placeholder="Duyuru/Kampanya Başlığı" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">İçerik Açıklaması</label>
          <textarea rows="3" oninput="updateAnnouncement(${idx}, 'content', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; width: 100%; resize: vertical; font-family: sans-serif;" placeholder="İçerik detayı...">${ann.content}</textarea>
        </div>
      </div>
    `).join('');
  }

  window.deleteAnnouncement = function(idx) {
    if (confirm('Bu duyuruyu silmek istediğinize emin misiniz?')) {
      announcementsList.splice(idx, 1);
      renderAnnouncementsList();
    }
  };

  window.updateAnnouncement = function(idx, field, val) {
    announcementsList[idx][field] = val;
  };

  const btnAdd = document.getElementById('btn-add-announcement');
  if (btnAdd) {
    btnAdd.addEventListener('click', () => {
      const todayStr = new Date().toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
      announcementsList.unshift({
        id: Date.now().toString(),
        badge: 'Duyuru',
        title: '',
        date: todayStr,
        content: ''
      });
      renderAnnouncementsList();
    });
  }

  const btnSave = document.getElementById('btn-save-announcements');
  if (btnSave) {
    btnSave.addEventListener('click', async () => {
      const emptyItem = announcementsList.find(ann => !ann.title || !ann.content);
      if (emptyItem) {
        alert('Lütfen tüm başlık ve içerik açıklaması alanlarını doldurun.');
        return;
      }
      
      btnSave.disabled = true;
      btnSave.innerText = 'Yayınlanıyor... 🚀';
      
      try {
        const res = await fetch('/api/save-announcements', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ announcements: announcementsList })
        });
        
        const data = await res.json();
        if (data.success) {
          alert('Duyurular başarıyla güncellendi ve GitHub üzerinden yayına alındı! Değişikliklerin canlı sitede görünmesi yaklaşık 30-40 saniye sürecektir.');
        } else {
          alert('Kaydetme hatası: ' + data.error);
        }
      } catch (err) {
        alert('İletişim hatası: ' + err.message);
      } finally {
        btnSave.disabled = false;
        btnSave.innerText = 'Değişiklikleri Kaydet ve Yayınla 🚀';
      }
    });
  }


  // Period Selector Bindings
  const btnHour = document.getElementById('btn-period-hour');
  const btnDay = document.getElementById('btn-period-day');
  const btnMonth = document.getElementById('btn-period-month');

  function setPeriodButtonState(activeBtn) {
    [btnHour, btnDay, btnMonth].forEach(btn => {
      if (btn) {
        if (btn === activeBtn) {
          btn.style.background = '#1c1c28';
          btn.style.color = '#d4af37';
          btn.style.border = '1px solid #232335';
        } else {
          btn.style.background = 'transparent';
          btn.style.color = '#b4b4c6';
          btn.style.border = 'none';
        }
      }
    });
  }

  if (btnHour) {
    btnHour.addEventListener('click', () => {
      activePeriod = 'hour';
      setPeriodButtonState(btnHour);
      loadAnalytics('hour');
    });
  }
  if (btnDay) {
    btnDay.addEventListener('click', () => {
      activePeriod = 'day';
      setPeriodButtonState(btnDay);
      loadAnalytics('day');
    });
  }
  if (btnMonth) {
    btnMonth.addEventListener('click', () => {
      activePeriod = 'month';
      setPeriodButtonState(btnMonth);
      loadAnalytics('month');
    });
  }

  async function loadAnalytics(period = 'day') {
    const badge = document.getElementById('kv-status-badge');
    const popularPage = document.getElementById('stat-popular-page');
    const totalViews = document.getElementById('stat-total-views');
    const todayViews = document.getElementById('stat-today-views');
    const kvInstructions = document.getElementById('kv-instructions');
    
    try {
      const res = await fetch(`/api/analytics?period=${period}`);
      const data = await res.json();
      
      // Connection Status Check
      if (data.isLive) {
        badge.innerText = '● Canlı İzleme Aktif';
        badge.style.color = '#10b981';
        badge.style.background = 'rgba(16,185,129,0.1)';
        badge.style.borderColor = 'rgba(16,185,129,0.2)';
        if (kvInstructions) kvInstructions.style.display = 'none';
      } else {
        badge.innerText = '● Simülasyon Modu';
        badge.style.color = '#f5a623';
        badge.style.background = 'rgba(245,166,35,0.1)';
        badge.style.borderColor = 'rgba(245,166,35,0.2)';
        if (kvInstructions) kvInstructions.style.display = 'block';
      }

      // Render Diagnostics Checklist
      const diagPanel = document.getElementById('diagnostics-panel');
      if (diagPanel && data.diagnostics) {
        diagPanel.style.display = 'block';
        const env = data.diagnostics.env;
        const err = data.diagnostics.error;
        
        let diagHtml = `<strong style="color: #fff; display: block; margin-bottom: 0.5rem; font-size: 0.85rem;">Sistem Tanılama Raporu:</strong>`;
        diagHtml += `<ul style="list-style: none; padding: 0; margin: 0 0 0.75rem 0; display: flex; flex-wrap: wrap; gap: 0.75rem; font-size: 0.75rem;">`;
        
        const kvOk = env.KV_REST_API_URL && env.KV_REST_API_TOKEN;
        const upstashOk = env.UPSTASH_REDIS_REST_URL && env.UPSTASH_REDIS_REST_TOKEN;
        
        diagHtml += `<li>Standart Redis (TCP): ${env.REDIS_URL ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>Vercel KV (REST): ${kvOk ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>Upstash (REST): ${upstashOk ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>GitHub Token: ${env.GITHUB_TOKEN ? '✅ Tanımlı' : '❌ Tanımsız'}</li>`;
        diagHtml += `</ul>`;
        
        if (err) {
          diagHtml += `<div style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15); padding: 0.5rem 0.75rem; border-radius: 6px; color: #fca5a5; font-family: monospace; font-size: 0.75rem; word-break: break-all;">Sistem Mesajı: ${err}</div>`;
        } else {
          diagHtml += `<div style="color: #10b981; font-weight: 500; font-size: 0.75rem;">✓ Veritabanı bağlantısı sorunsuz kuruldu. Canlı trafik izleniyor.</div>`;
        }
        
        diagPanel.innerHTML = diagHtml;
      }
      
      // Calculate statistics metrics
      const sortedPV = Object.entries(data.pageviews).sort((a,b) => b[1] - a[1]);
      const totalPV = Object.values(data.pageviews).reduce((sum, v) => sum + v, 0);
      const topPage = sortedPV[0] ? sortedPV[0][0] : 'Yok';
      
      // Calculate views sum for active period
      const periodSum = data.dailyViews.reduce((sum, d) => sum + d.views, 0);

      totalViews.innerText = totalPV.toLocaleString();
      popularPage.innerText = topPage;
      todayViews.innerText = periodSum.toLocaleString();

      // Render Bar Chart (Page Views)
      const maxPV = sortedPV[0] ? sortedPV[0][1] : 1;
      let barHtml = '';
      sortedPV.forEach(([path, count]) => {
        const pct = (count / maxPV) * 100;
        barHtml += `
          <div style="margin-bottom: 1.25rem;">
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: #b4b4c6; margin-bottom: 0.35rem;">
              <span style="color: #fff; font-size:0.85rem; font-weight: 500;">${path}</span>
              <strong style="color: #d4af37;">${count} Tıklama</strong>
            </div>
            <div style="background: #161622; height: 8px; border-radius: 4px; overflow: hidden; border: 1px solid #1f1f2e;">
              <div style="background: linear-gradient(90deg, #d4af37, #f5a623); width: ${pct}%; height: 100%; border-radius: 4px; transition: width 0.8s ease-out;"></div>
            </div>
          </div>
        `;
      });
      document.getElementById('pageviews-list').innerHTML = barHtml;

      // Render Line Chart (Daily Traffic) via SVG Math
      const maxViews = Math.max(...data.dailyViews.map(d => d.views), 10);
      const pointCount = data.dailyViews.length;
      const spacing = 500 / (pointCount - 1);
      
      const points = data.dailyViews.map((d, i) => {
        const x = i * spacing;
        const y = 130 - (d.views / maxViews) * 100;
        return `${x},${y}`;
      });

      // SVG path line definition
      const pathD = 'M ' + points.join(' L ');
      document.getElementById('traffic-line').setAttribute('d', pathD);

      // SVG area boundary
      const areaD = `${pathD} L 500,130 L 0,130 Z`;
      document.getElementById('traffic-area').setAttribute('d', areaD);

      // Render bottom labels for dates (filter hourly to keep clean)
      const labelsContainer = document.getElementById('traffic-labels');
      let labelsHtml = '';
      data.dailyViews.forEach((d, index) => {
        if (period === 'hour' && index % 4 !== 0 && index !== pointCount - 1) {
          return;
        }
        labelsHtml += `<span>${d.date}</span>`;
      });
      labelsContainer.innerHTML = labelsHtml;

    } catch (e) {
      console.error('Error fetching analytics details:', e);
    }
  }
</script>
