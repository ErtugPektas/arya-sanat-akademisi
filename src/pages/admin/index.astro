      const courseName = document.getElementById('erp-new-lesson-course').value.trim();
      const teacherName = document.getElementById('erp-new-lesson-teacher').value.trim();
      const studio = document.getElementById('erp-new-lesson-studio').value.trim();
      const day = document.getElementById('erp-new-lesson-day').value;
      const time = document.getElementById('erp-new-lesson-time').value.trim();

      if (!studentName || !courseName || !teacherName || !studio || !time) {
