---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

let errorMsg = '';
const adminPassword = process.env.ADMIN_PASSWORD || 'arya2026';

// Check logout
const url = new URL(Astro.request.url);
if (url.searchParams.get('action') === 'logout') {
  Astro.cookies.delete('admin_session', { path: '/' });
  return Astro.redirect('/admin');
}

// Handle login post
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const password = data.get('password');
    
    if (password === adminPassword) {
      Astro.cookies.set('admin_session', 'true', { path: '/', maxAge: 86400, httpOnly: true, sameSite: 'strict' });
      return Astro.redirect('/admin');
    } else {
      errorMsg = 'Geçersiz şifre, lütfen tekrar deneyin.';
    }
  } catch (e) {
    errorMsg = 'Bir hata oluştu.';
  }
}

// Check session
const isLoggedIn = Astro.cookies.has('admin_session') && Astro.cookies.get('admin_session').value === 'true';

let courses = [];
if (isLoggedIn) {
  courses = await getCollection('kurslar');
}
---

<Layout title="Yönetim Paneli | Arya Sanat Akademisi" description="Arya Sanat Akademisi Yönetim Paneli">
  <link rel="stylesheet" href="/css/style.css" slot="head" />
  
  <div class="admin-container" style="min-height: 100vh; padding: 0 0 4rem 0; background: #07070a; color: #fff; font-family: sans-serif;">
    
    <!-- CUSTOM ADMIN TOPBAR -->
    {isLoggedIn && (
      <div style="background: #101016; border-bottom: 1px solid #1f1f2e; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <span style="font-size: 1.5rem; color: #d4af37;">♩</span>
          <div>
            <strong style="color: #fff; font-size: 1.05rem; display: block; font-weight: 700;">Arya Sanat</strong>
            <span style="color: #d4af37; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">Yönetim Paneli</span>
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: 1.5rem;">
          <a href="/" target="_blank" style="color: #b4b4c6; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#b4b4c6'"> Canlı Siteyi Gör 🌐</a>
          <a 
            href="/admin?action=logout" 
            style="background: rgba(239, 68, 68, 0.12); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.25); padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
            onmouseover="this.style.background='rgba(239, 68, 68, 0.2)'; this.style.borderColor='rgba(239,68,68,0.4)';"
            onmouseout="this.style.background='rgba(239, 68, 68, 0.12)'; this.style.borderColor='rgba(239,68,68,0.25)';"
          >
            Güvenli Çıkış 🚪
          </a>
        </div>
      </div>
    )}

    <div style="max-width: 1000px; margin: 0 auto; padding: 3rem 1.5rem;">
      
      {!isLoggedIn ? (
        // PREMIUM LOGIN FORM
        <div style="max-width: 420px; margin: 4rem auto; background: #101016; padding: 3rem 2.5rem; border-radius: 16px; border: 1px solid #1f1f2e; box-shadow: 0 20px 50px rgba(0,0,0,0.6); position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #d4af37, #f5a623);"></div>
          
          <div style="text-align: center; margin-bottom: 2.5rem;">
            <span style="font-size: 3.5rem; filter: drop-shadow(0 0 15px rgba(212,175,55,0.3));">🔐</span>
            <h1 style="font-size: 1.75rem; margin-top: 1.25rem; color: #fff; font-weight: 800; letter-spacing: -0.02em;">Yönetici Girişi</h1>
            <p style="color: #8b8b9f; font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.5;">İçerikleri düzenlemek ve web sitesini güncellemek için şifrenizi girin</p>
          </div>
          
          {errorMsg && (
            <div style="background: rgba(239, 68, 68, 0.12); border: 1px solid #ef4444; color: #fca5a5; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 2rem; font-size: 0.85rem; text-align: center; font-weight: 500;">
              ⚠️ {errorMsg}
            </div>
          )}
          
          <form method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label for="password" style="font-size: 0.8rem; color: #a4a4b6; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">Giriş Şifresi</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                required 
                style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.9rem 1.1rem; border-radius: 8px; font-size: 1rem; outline: none; transition: border-color 0.2s;"
                placeholder="••••••••"
              />
            </div>
            
            <button 
              type="submit" 
              style="background: linear-gradient(135deg, #d4af37 0%, #aa841c 100%); color: #000; border: none; padding: 1rem; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(212,175,55,0.25);"
              onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(212,175,55,0.4)';"
              onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(212,175,55,0.25)';"
            >
              Giriş Yap
            </button>
          </form>
        </div>
      ) : (
        // DASHBOARD WITH LAYERED GRID & STATS
        <div>
          
          <!-- Welcome Bar -->
          <div style="margin-bottom: 3rem;">
            <h1 style="font-size: 2.2rem; font-weight: 800; color: #fff; margin: 0; letter-spacing: -0.02em;">Yönetim Masası</h1>
            <p style="color: #8b8b9f; margin-top: 0.5rem; font-size: 1rem;">Arya Sanat Akademisi web sitesi içerik yönetim alanı</p>
          </div>

          <!-- Katmanlı Özet Paneli (Stats Grid) -->
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 3.5rem;">
            <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
              <span style="font-size: 2.2rem; background: rgba(212,175,55,0.1); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #d4af37;">📚</span>
              <div>
                <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Aktif Programlar</span>
                <strong style="color: #fff; font-size: 1.5rem; display: block; margin-top: 0.25rem;">{courses.length} Kurs</strong>
              </div>
            </div>
            <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
              <span style="font-size: 2.2rem; background: rgba(34,139,34,0.1); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #228b22;">📜</span>
              <div>
                <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Sertifikasyon</span>
                <strong style="color: #fff; font-size: 1.5rem; display: block; margin-top: 0.25rem;">MEB Onaylı</strong>
              </div>
            </div>
            <div style="background: #101016; border: 1px solid #1f1f2e; padding: 1.5rem; border-radius: 12px; display: flex; align-items: center; gap: 1.25rem;">
              <span style="font-size: 2.2rem; background: rgba(30,144,255,0.1); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: #1e90ff;">🏛️</span>
              <div>
                <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Konum Detayı</span>
                <strong style="color: #fff; font-size: 1.5rem; display: block; margin-top: 0.25rem;">Kocasinan</strong>
              </div>
            </div>
          </div>

          <!-- Section Title -->
          <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 2rem; color: #d4af37; display: flex; align-items: center; gap: 0.75rem; border-bottom: 1px solid #1f1f2e; padding-bottom: 0.75rem;">
            <span>📚 Kurs Detay Sayfaları</span>
            <span style="font-size: 0.85rem; font-weight: 500; color: #8b8b9f; background: #1c1c28; padding: 0.2rem 0.6rem; border-radius: 12px; margin-left: auto;">{courses.length} Toplam</span>
          </h2>

          <!-- Course Cards Grid -->
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            {courses.map((course) => (
              <div class="admin-course-card" style="background: #101016; border: 1px solid #1f1f2e; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                <div style="height: 180px; overflow: hidden; position: relative;">
                  <img 
                    src={course.data.image} 
                    alt={course.data.heroTitle} 
                    style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;"
                  />
                  <div style="position: absolute; top: 12px; left: 12px; background: rgba(7,7,10,0.85); border: 1px solid rgba(212,175,55,0.3); padding: 0.35rem 0.75rem; border-radius: 20px; font-size: 0.8rem; color: #d4af37; font-weight: 600;">
                    {course.data.badge}
                  </div>
                </div>
                
                <div style="padding: 1.75rem; display: flex; flex-direction: column; flex-grow: 1; gap: 1.25rem;">
                  <div>
                    <h3 style="font-size: 1.3rem; font-weight: 700; margin: 0; color: #fff; letter-spacing: -0.01em;">{course.data.heroTitle}</h3>
                    <p style="color: #8b8b9f; font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                      {course.data.description}
                    </p>
                  </div>
                  
                  <div style="background: #161622; border-radius: 8px; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: #b4b4c6; border: 1px solid #1f1f2e;">
                    <div style="display:flex; justify-content:space-between;"><span>⏱️ Süre:</span> <strong style="color:#fff;">{course.data.duration}</strong></div>
                    <div style="display:flex; justify-content:space-between;"><span>📅 Sıklık:</span> <strong style="color:#fff;">{course.data.frequency}</strong></div>
                    <div style="display:flex; justify-content:space-between;"><span>👨‍🏫 Eğitmen:</span> <strong style="color:#fff;">{course.data.teacher.name}</strong></div>
                  </div>
                  
                  <a 
                    href={`/admin/edit?course=${course.id}`}
                    style="display: block; text-align: center; background: #1c1c28; color: #fff; border: 1px solid #232335; padding: 0.85rem; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.25s; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                    onmouseover="this.style.background='#d4af37'; this.style.color='#000'; this.style.borderColor='#d4af37'; this.style.boxShadow='0 4px 12px rgba(212,175,55,0.3)';"
                    onmouseout="this.style.background='#1c1c28'; this.style.color='#fff'; this.style.borderColor='#232335'; this.style.boxShadow='none';"
                  >
                    Sayfayı Düzenle ✏️
                  </a>
                </div>
              </div>
            ))}
          </div>
          
          <!-- Hint Card -->
          <div style="margin-top: 4rem; background: #101016; border: 1px solid #1f1f2e; padding: 2rem; border-radius: 16px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
            <div>
              <h3 style="margin: 0; font-size: 1.15rem; color: #fff; font-weight: 700;">💡 İpucu: Site Şifresini Değiştirme</h3>
              <p style="margin: 0.5rem 0 0 0; color: #8b8b9f; font-size: 0.9rem; line-height: 1.5;">
                Giriş şifresini değiştirmek için Vercel Dashboard'unuzdaki <strong>ADMIN_PASSWORD</strong> ortam değişkenini güncelleyebilirsiniz.
              </p>
            </div>
            <a 
              href="https://vercel.com/ertugpektas/arya-sanat-akademisi/settings/environment-variables" 
              target="_blank"
              style="background: #1c1c28; color: #fff; border: 1px solid #232335; padding: 0.75rem 1.25rem; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
              onmouseover="this.style.background='#222230'; this.style.borderColor='#33334d';"
              onmouseout="this.style.background='#1c1c28'; this.style.borderColor='#232335';"
            >
              Vercel Ayarlarına Git 🔗
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
</Layout>
