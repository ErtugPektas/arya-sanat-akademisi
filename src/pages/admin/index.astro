                      <input type="text" id="erp-new-teacher-name" placeholder="Eğitmen Ad Soyad" style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.8rem;" />
                      <input type="text" id="erp-new-teacher-spec" placeholder="Branş (Örn: Piyano)" style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.8rem;" />
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                      <div style="display: flex; align-items: center; background: #1a1a2a; border: 1px solid #2d2d42; border-radius: 6px; padding: 0 0.5rem;">
                        <input type="number" id="erp-new-teacher-rate" placeholder="Saatlik Hakediş" value="300" style="background: transparent; border: none; color: #fff; padding: 0.4rem 0.1rem; width: 100%; font-size: 0.8rem; outline: none;" />
                        <span style="color: #8b8b9f; font-size: 0.8rem; font-weight: 600;">₺/Sa</span>
                      </div>
                      <input type="text" id="erp-new-teacher-password" placeholder="Giriş Şifresi" style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.8rem;" />
                    </div>
                    <div style="display: flex; justify-content: flex-end;">
                      <button onclick="addNewTeacher()" style="background: #d4af37; color: #000; border: none; padding: 0.45rem 1.5rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; cursor: pointer; width: 100%;">Eğitmen Ekle</button>
                    </div>
                  </div>

                  <!-- Teachers List Table -->
                  <div style="max-height: 180px; overflow-y: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.8rem; color: #b4b4c6;">
                      <thead>
                        <tr style="border-bottom: 1px solid #1f1f2e; color: #fff;">
                          <th style="padding: 0.25rem;">Eğitmen</th>
                          <th style="padding: 0.25rem;">Branş</th>
                          <th style="padding: 0.25rem; text-align: right;">Saatlik Ücret</th>
                          <th style="padding: 0.25rem; text-align: center;">İşlem</th>
                        </tr>
                      </thead>
                      <tbody id="erp-teachers-list-tbody">
                        <!-- Rendered via JS -->
                      </tbody>
                    </table>
                  </div>
                </div>

                <!-- 2. Hakediş & Kurum Kazanç Hesaplayıcı -->
                <div style="background: #101016; border: 1px solid #1f1f2e; padding: 2rem; border-radius: 16px;">
                  <h3 style="margin: 0 0 0.5rem 0; font-size: 1.15rem; color: #fff; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color: #10b981;"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                    <span>💰 Hakediş &amp; Kurum Kar Dağılımı</span>
                  </h3>
                  <p style="color: #8b8b9f; margin-bottom: 1.5rem; font-size: 0.8rem;">Seçili döneme göre tahsil edilen aidatlardan eğitmene kalan ve kuruma kalan net kar oranları.</p>
                  
                  <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.8rem; color: #b4b4c6;">
                      <thead>
                        <tr style="border-bottom: 1px solid #1f1f2e; color: #fff;">
                          <th style="padding: 0.25rem;">Eğitmen</th>
                          <th style="padding: 0.25rem; text-align: center;">Ders Saati</th>
