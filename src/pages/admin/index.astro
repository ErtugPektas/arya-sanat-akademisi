        alert('Lütfen ad, telefon ve eğitmen alanlarını doldurunuz.');
        return;
      }

      const initialPayments = {};
      initialPayments[erpActiveMonth] = 'Unpaid';
      
      const initialAttendance = {};
      initialAttendance[erpActiveMonth] = { attended: 0, total: 4 };

      const initialNotes = {};
      initialNotes[erpActiveMonth] = '';

      const initialProgress = {};
      initialProgress[erpActiveMonth] = 0;

      erpDataObj.students.push({
        id: 'std_' + Date.now(),
        name,
        phone,
        courseId,
        teacherName,
        monthlyFee,
        payments: initialPayments,
        attendance: initialAttendance,
        notes: initialNotes,
        progress: initialProgress
      });
      panelAddStudent.style.display = 'none';
      document.getElementById('erp-new-student-name').value = '';
      document.getElementById('erp-new-student-phone').value = '';
      document.getElementById('erp-new-student-teacher').selectedIndex = 0;

      await saveErpData();
