                          {t}
                        </button>
                      ))}
                    </div>
                  </div>
                  <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1rem;">
                    <button id="btn-save-new-lesson" style="background: #10b981; color: #fff; border: none; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 700; cursor: pointer; font-size: 0.85rem;">Dersi Planla</button>
                    <button id="btn-cancel-new-lesson" style="background: transparent; color: #8b8b9f; border: 1px solid #2d2d42; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem;">İptal</button>
                  </div>
                </div>

                <!-- Schedule Card List -->
                <div id="erp-lessons-list" style="display: flex; flex-direction: column; gap: 1rem;">
                </div>
              </div>

            </div>

            <!-- Payouts / Payroll & Instructor Management Section (Admin only) -->
            {role === 'admin' && (
              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; margin-bottom: 2rem;">
                
                <!-- 1. Eğitmen Tanımlama ve Listesi -->
                <div style="background: #101016; border: 1px solid #1f1f2e; padding: 2rem; border-radius: 16px;">
                  <h3 style="margin: 0 0 0.5rem 0; font-size: 1.15rem; color: #fff; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color: #d4af37;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    <span>👨‍🏫 Eğitmen Yönetimi</span>
                  </h3>
                  <p style="color: #8b8b9f; margin-bottom: 1.5rem; font-size: 0.8rem;">Yeni eğitmen ekleyin, uzmanlık alanı ve saatlik mesai hakediş oranını belirleyin.</p>
                  
                  <!-- Add Teacher Form -->
