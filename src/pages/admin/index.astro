                  <textarea name="seo_desc" rows="2" required style="background: #161622; border: 1px solid #1f1f2e; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; font-size: 0.9rem; outline: none; width: 100%; resize: vertical; font-family: sans-serif;">{siteSettings.seo.description}</textarea>
                </div>
              </fieldset>

              <!-- 2. İletişim Bilgileri -->
