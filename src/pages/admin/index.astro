                    </div>
                  </div>
                  <div style="margin-top: 1rem;">
                    <label style="font-size: 0.75rem; color: #a4a4b6; font-weight: 600; display: block; margin-bottom: 0.5rem;">Ders Günü Seçin</label>
                    <input type="hidden" id="erp-new-lesson-day" value="Pazartesi" />
                    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;" id="erp-day-chips">
                      {['Pazartesi', 'Salı', 'Çarşamba', 'Perşembe', 'Cuma', 'Cumartesi', 'Pazar'].map((d, i) => (
                        <button type="button" onclick={`selectLessonDay('${d}')`} id={`day-chip-${d}`} class={`day-chip-btn ${i===0?'selected':''}`} style="background: #1a1a2a; border: 1px solid #2d2d42; color: #b4b4c6; padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease;">
                          {d}
                        </button>
                      ))}
                    </div>
                  </div>

                  <div style="margin-top: 1rem; margin-bottom: 1rem;">
                    <label style="font-size: 0.75rem; color: #a4a4b6; font-weight: 600; display: block; margin-bottom: 0.5rem;">Ders Saati Seçin</label>
                    <input type="hidden" id="erp-new-lesson-time" value="09:00 - 10:00" />
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.5rem;" id="erp-time-slots">
                      {[
                        '09:00 - 10:00', '10:00 - 11:00', '11:00 - 12:00', '12:00 - 13:00',
                        '13:00 - 14:00', '14:00 - 15:00', '15:00 - 16:00', '16:00 - 17:00',
                        '17:00 - 18:00', '18:00 - 19:00', '19:00 - 20:00', '20:00 - 21:00'
                      ].map((t, i) => (
