                      <input type="text" id="erp-new-student-name" placeholder="Ahmet Yılmaz" style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.85rem; outline: none;" />
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                      <label style="font-size: 0.75rem; color: #a4a4b6;">Telefon Numarası</label>
                      <input type="text" id="erp-new-student-phone" placeholder="+90 532 ..." style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.85rem; outline: none;" />
                    </div>
                  </div>
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.75rem;">
                    <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                      <label style="font-size: 0.75rem; color: #a4a4b6;">Kurs</label>
                      <select id="erp-new-student-course" style="background: #1a1a2a; border: 1px solid #2d2d42; color: #fff; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.85rem; outline: none;">
