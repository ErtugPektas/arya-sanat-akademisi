        document.querySelectorAll('[name^="hero_"]').forEach(el => {
          const key = el.name.replace('hero_', '');
          const mappedKey = key === 'highlight' ? 'titleHighlight' : key;
          if (settings.hero[mappedKey] !== undefined) {
            el.value = settings.hero[mappedKey];
          }
