  syncInputsFromCache();

  const tabCourses = document.getElementById('tab-courses');
  const tabAnnouncements = document.getElementById('tab-announcements');
  const tabAnalytics = document.getElementById('tab-analytics');
  const tabErp = document.getElementById('tab-erp');
  const tabSettings = document.getElementById('tab-settings');
  
  const secCourses = document.getElementById('sec-courses');
  const secAnnouncements = document.getElementById('sec-announcements');
  const secAnalytics = document.getElementById('sec-analytics');
  const secErp = document.getElementById('sec-erp');
  const secSettings = document.getElementById('sec-settings');

  let activePeriod = 'day'; // Default period

  function resetTabs() {
    [tabCourses, tabAnnouncements, tabAnalytics, tabErp, tabSettings].forEach(tab => {
      if (tab) {
        tab.style.background = '#101016';
        tab.style.color = '#b4b4c6';
        tab.style.borderColor = '#1f1f2e';
      }
    });
    [secCourses, secAnnouncements, secAnalytics, secErp, secSettings].forEach(sec => {
      if (sec) {
        sec.style.display = 'none';
      }
    });
  }

  if (tabCourses) {
    tabCourses.addEventListener('click', () => {
      resetTabs();
      tabCourses.style.background = '#1c1c28';
      tabCourses.style.color = '#d4af37';
      tabCourses.style.borderColor = '#d4af37';
      if (secCourses) secCourses.style.display = 'block';
    });
  }

  if (tabAnnouncements) {
    tabAnnouncements.addEventListener('click', () => {
      resetTabs();
      tabAnnouncements.style.background = '#1c1c28';
      tabAnnouncements.style.color = '#d4af37';
      tabAnnouncements.style.borderColor = '#d4af37';
      if (secAnnouncements) {
        secAnnouncements.style.display = 'block';
        renderAnnouncementsList();
      }
    });
  }

  if (tabAnalytics) {
    tabAnalytics.addEventListener('click', () => {
      resetTabs();
      tabAnalytics.style.background = '#1c1c28';
      tabAnalytics.style.color = '#d4af37';
      tabAnalytics.style.borderColor = '#d4af37';
      if (secAnalytics) {
        secAnalytics.style.display = 'block';
        loadAnalytics(activePeriod);
      }
    });
  }

  if (tabErp) {
    tabErp.addEventListener('click', () => {
      resetTabs();
      tabErp.style.background = '#1c1c28';
      tabErp.style.color = '#d4af37';
      tabErp.style.borderColor = '#d4af37';
      if (secErp) {
        secErp.style.display = 'block';
        renderErpDashboard();
      }
    });
  }

  if (tabSettings) {
    tabSettings.addEventListener('click', () => {
      resetTabs();
      tabSettings.style.background = '#1c1c28';
      tabSettings.style.color = '#d4af37';
      tabSettings.style.borderColor = '#d4af37';
      if (secSettings) secSettings.style.display = 'block';
    });
  }

  // Auto-focus ERP tab for teachers on mount
  if (userRole === 'teacher' && tabErp) {
    tabErp.style.background = '#1c1c28';
    tabErp.style.color = '#d4af37';
    tabErp.style.borderColor = '#d4af37';
    if (secErp) secErp.style.display = 'block';
    // Run initial render after script parses
    setTimeout(() => {
      renderErpDashboard();
    }, 100);
  }

  // ANNOUNCEMENTS MANAGEMENT LOGIC
  let announcementsList = [...initialAnnouncements];
  const listContainer = document.getElementById('announcements-editor-list');

  function renderAnnouncementsList() {
    if (!listContainer) return;
    
    if (announcementsList.length === 0) {
      listContainer.innerHTML = `
        <div style="text-align: center; padding: 4rem 2rem; background: #101016; border: 1px solid #1f1f2e; border-radius: 16px; color: #8b8b9f;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #8b8b9f; margin-bottom: 1rem;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <p style="margin: 0; font-size: 1rem; font-weight: 500;">Henüz eklenmiş bir duyuru veya kampanya bulunmuyor.</p>
        </div>
      `;
      return;
    }
    
    listContainer.innerHTML = announcementsList.map((ann, idx) => `
      <div style="background: #101016; border: 1px solid #1f1f2e; border-radius: 12px; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative;">
        <button onclick="deleteAnnouncement(${idx})" style="position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); padding: 0.45rem 0.9rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">Kaldır 🗑️</button>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 80%;">
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Etiket (Badge)</label>
            <select onchange="updateAnnouncement(${idx}, 'badge', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; cursor: pointer;">
              <option value="Kampanya" ${ann.badge === 'Kampanya' ? 'selected' : ''}>Kampanya 🎁</option>
              <option value="Duyuru" ${ann.badge === 'Duyuru' ? 'selected' : ''}>Duyuru 📢</option>
            </select>
          </div>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Tarih</label>
            <input type="text" value="${ann.date}" oninput="updateAnnouncement(${idx}, 'date', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem;" placeholder="Örn: 15 Temmuz 2026" />
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Başlık</label>
          <input type="text" value="${ann.title}" oninput="updateAnnouncement(${idx}, 'title', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; width: 100%;" placeholder="Duyuru/Kampanya Başlığı" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">İçerik Açıklaması</label>
          <textarea rows="3" oninput="updateAnnouncement(${idx}, 'content', this.value)" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.65rem 0.85rem; border-radius: 6px; outline: none; font-size: 0.9rem; width: 100%; resize: vertical; font-family: sans-serif;" placeholder="İçerik detayı...">${ann.content}</textarea>
        </div>
      </div>
    `).join('');
  }

  window.deleteAnnouncement = function(idx) {
    if (confirm('Bu duyuruyu silmek istediğinize emin misiniz?')) {
      announcementsList.splice(idx, 1);
      renderAnnouncementsList();
    }
  };

  window.updateAnnouncement = function(idx, field, val) {
    announcementsList[idx][field] = val;
  };

  const btnAdd = document.getElementById('btn-add-announcement');
  if (btnAdd) {
    btnAdd.addEventListener('click', () => {
      const todayStr = new Date().toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
      announcementsList.unshift({
        id: Date.now().toString(),
        badge: 'Duyuru',
        title: '',
        date: todayStr,
        content: ''
      });
      renderAnnouncementsList();
    });
  }

  const btnSave = document.getElementById('btn-save-announcements');
  if (btnSave) {
    btnSave.addEventListener('click', async () => {
      const emptyItem = announcementsList.find(ann => !ann.title || !ann.content);
      if (emptyItem) {
        alert('Lütfen tüm başlık ve içerik açıklaması alanlarını doldurun.');
        return;
      }
      
      btnSave.disabled = true;
      btnSave.innerText = 'Yayınlanıyor... 🚀';
      
      try {
        const res = await fetch('/api/save-announcements', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ announcements: announcementsList })
        });
        
        const data = await res.json();
        if (data.success) {
          alert('Duyurular başarıyla güncellendi ve GitHub üzerinden yayına alındı! Değişikliklerin canlı sitede görünmesi yaklaşık 30-40 saniye sürecektir.');
        } else {
          alert('Kaydetme hatası: ' + data.error);
        }
      } catch (err) {
        alert('İletişim hatası: ' + err.message);
      } finally {
        btnSave.disabled = false;
        btnSave.innerText = 'Değişiklikleri Kaydet ve Yayınla 🚀';
      }
    });
  }


  // Period Selector Bindings
  const btnHour = document.getElementById('btn-period-hour');
  const btnDay = document.getElementById('btn-period-day');
  const btnMonth = document.getElementById('btn-period-month');

  function setPeriodButtonState(activeBtn) {
    [btnHour, btnDay, btnMonth].forEach(btn => {
      if (btn) {
        if (btn === activeBtn) {
          btn.style.background = '#1c1c28';
          btn.style.color = '#d4af37';
          btn.style.border = '1px solid #232335';
        } else {
          btn.style.background = 'transparent';
          btn.style.color = '#b4b4c6';
          btn.style.border = 'none';
        }
      }
    });
  }

  if (btnHour) {
    btnHour.addEventListener('click', () => {
      activePeriod = 'hour';
      setPeriodButtonState(btnHour);
      loadAnalytics('hour');
    });
  }
  if (btnDay) {
    btnDay.addEventListener('click', () => {
      activePeriod = 'day';
      setPeriodButtonState(btnDay);
      loadAnalytics('day');
    });
  }
  if (btnMonth) {
    btnMonth.addEventListener('click', () => {
      activePeriod = 'month';
      setPeriodButtonState(btnMonth);
      loadAnalytics('month');
    });
  }

  async function loadAnalytics(period = 'day') {
    const badge = document.getElementById('kv-status-badge');
    const popularPage = document.getElementById('stat-popular-page');
    const totalViews = document.getElementById('stat-total-views');
    const todayViews = document.getElementById('stat-today-views');
    const kvInstructions = document.getElementById('kv-instructions');
    
    try {
      const res = await fetch(`/api/analytics?period=${period}`);
      const data = await res.json();
      
      // Connection Status Check
      if (data.isLive) {
        badge.innerText = '● Canlı İzleme Aktif';
        badge.style.color = '#10b981';
        badge.style.background = 'rgba(16,185,129,0.1)';
        badge.style.borderColor = 'rgba(16,185,129,0.2)';
        if (kvInstructions) kvInstructions.style.display = 'none';
      } else {
        badge.innerText = '● Simülasyon Modu';
        badge.style.color = '#f5a623';
        badge.style.background = 'rgba(245,166,35,0.1)';
        badge.style.borderColor = 'rgba(245,166,35,0.2)';
        if (kvInstructions) kvInstructions.style.display = 'block';
      }

      // Render Diagnostics Checklist
      const diagPanel = document.getElementById('diagnostics-panel');
      if (diagPanel && data.diagnostics) {
        diagPanel.style.display = 'block';
        const env = data.diagnostics.env;
        const err = data.diagnostics.error;
        
        let diagHtml = `<strong style="color: #fff; display: block; margin-bottom: 0.5rem; font-size: 0.85rem;">Sistem Tanılama Raporu:</strong>`;
        diagHtml += `<ul style="list-style: none; padding: 0; margin: 0 0 0.75rem 0; display: flex; flex-wrap: wrap; gap: 0.75rem; font-size: 0.75rem;">`;
        
        const kvOk = env.KV_REST_API_URL && env.KV_REST_API_TOKEN;
        const upstashOk = env.UPSTASH_REDIS_REST_URL && env.UPSTASH_REDIS_REST_TOKEN;
        
        diagHtml += `<li>Standart Redis (TCP): ${env.REDIS_URL ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>Vercel KV (REST): ${kvOk ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>Upstash (REST): ${upstashOk ? '✅ Aktif' : '❌ Bağlı Değil'}</li>`;
        diagHtml += `<li>GitHub Token: ${env.GITHUB_TOKEN ? '✅ Tanımlı' : '❌ Tanımsız'}</li>`;
        diagHtml += `</ul>`;
        
        if (err) {
          diagHtml += `<div style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15); padding: 0.5rem 0.75rem; border-radius: 6px; color: #fca5a5; font-family: monospace; font-size: 0.75rem; word-break: break-all;">Sistem Mesajı: ${err}</div>`;
        } else {
          diagHtml += `<div style="color: #10b981; font-weight: 500; font-size: 0.75rem;">✓ Veritabanı bağlantısı sorunsuz kuruldu. Canlı trafik izleniyor.</div>`;
        }
        
        diagPanel.innerHTML = diagHtml;
      }
      
      // Calculate statistics metrics
      const sortedPV = Object.entries(data.pageviews).sort((a,b) => b[1] - a[1]);
      const totalPV = Object.values(data.pageviews).reduce((sum, v) => sum + v, 0);
      const topPage = sortedPV[0] ? sortedPV[0][0] : 'Yok';
      
      // Calculate views sum for active period
      const periodSum = data.dailyViews.reduce((sum, d) => sum + d.views, 0);

      totalViews.innerText = totalPV.toLocaleString();
      popularPage.innerText = topPage;
      todayViews.innerText = periodSum.toLocaleString();

      // Render Bar Chart (Page Views)
      const maxPV = sortedPV[0] ? sortedPV[0][1] : 1;
      let barHtml = '';
      sortedPV.forEach(([path, count]) => {
        const pct = (count / maxPV) * 100;
        barHtml += `
          <div style="margin-bottom: 1.25rem;">
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: #b4b4c6; margin-bottom: 0.35rem;">
              <span style="color: #fff; font-size:0.85rem; font-weight: 500;">${path}</span>
              <strong style="color: #d4af37;">${count} Tıklama</strong>
            </div>
            <div style="background: #161622; height: 8px; border-radius: 4px; overflow: hidden; border: 1px solid #1f1f2e;">
              <div style="background: linear-gradient(90deg, #d4af37, #f5a623); width: ${pct}%; height: 100%; border-radius: 4px; transition: width 0.8s ease-out;"></div>
            </div>
          </div>
        `;
      });
      document.getElementById('pageviews-list').innerHTML = barHtml;

      // Render Line Chart (Daily Traffic) via SVG Math
      const maxViews = Math.max(...data.dailyViews.map(d => d.views), 10);
      const pointCount = data.dailyViews.length;
      const spacing = 500 / (pointCount - 1);
      
      const points = data.dailyViews.map((d, i) => {
        const x = i * spacing;
        const y = 130 - (d.views / maxViews) * 100;
        return `${x},${y}`;
      });

      // SVG path line definition
      const pathD = 'M ' + points.join(' L ');
      document.getElementById('traffic-line').setAttribute('d', pathD);

      // SVG area boundary
      const areaD = `${pathD} L 500,130 L 0,130 Z`;
      document.getElementById('traffic-area').setAttribute('d', areaD);

      // Render bottom labels for dates (filter hourly to keep clean)
      const labelsContainer = document.getElementById('traffic-labels');
      let labelsHtml = '';
      data.dailyViews.forEach((d, index) => {
        if (period === 'hour' && index % 4 !== 0 && index !== pointCount - 1) {
          return;
        }
        labelsHtml += `<span>${d.date}</span>`;
      });
      labelsContainer.innerHTML = labelsHtml;

    } catch (e) {
      console.error('Error fetching analytics details:', e);
    }
  }

  // ACADEMY ERP MANAGEMENT LOGIC
  let erpDataObj = { 
    students: [], 
    lessons: [], 
    archivedStudents: [],
    teachers: []
  };

  try {
    const cached = localStorage.getItem('arya_erp_data');
    if (cached) {
      erpDataObj = { ...erpDataObj, ...JSON.parse(cached) };
    } else {
      erpDataObj = { ...erpDataObj, ...initialErpData };
    }
  } catch (e) {
    erpDataObj = { ...erpDataObj, ...initialErpData };
  }

  // Populate default teachers if empty
  if (!erpDataObj.teachers || erpDataObj.teachers.length === 0) {
    erpDataObj.teachers = [
      { id: 't_default_1', name: 'Elif SÖNMEZ', specialty: 'Piyano', hourlyRate: 350 },
      { id: 't_default_2', name: 'Mehmet KAYA', specialty: 'Bateri', hourlyRate: 300 }
    ];
  }

  const tbodyStudents = document.getElementById('erp-student-tbody');
  const listLessons = document.getElementById('erp-lessons-list');

  const panelAddStudent = document.getElementById('panel-add-student');
  const panelAddLesson = document.getElementById('panel-add-lesson');

  // Month Period State
  const selectMonth = document.getElementById('erp-period-month');
  const selectYear = document.getElementById('erp-period-year');

  function getActiveMonth() {
    const m = selectMonth ? selectMonth.value : '07';
    const y = selectYear ? selectYear.value : '2026';
    return `${y}-${m}`;
  }

  let erpActiveMonth = getActiveMonth();

  function onPeriodChange() {
    erpActiveMonth = getActiveMonth();
    renderErpDashboard();
  }

  if (selectMonth) selectMonth.addEventListener('change', onPeriodChange);
  if (selectYear) selectYear.addEventListener('change', onPeriodChange);

  // Toggle Forms
  const btnAddStudent = document.getElementById('btn-add-student');
  if (btnAddStudent && panelAddStudent) {
    btnAddStudent.addEventListener('click', () => {
      panelAddStudent.style.display = panelAddStudent.style.display === 'none' ? 'flex' : 'none';
    });
  }
  const btnCancelNewStudent = document.getElementById('btn-cancel-new-student');
  if (btnCancelNewStudent && panelAddStudent) {
    btnCancelNewStudent.addEventListener('click', (e) => {
      e.preventDefault();
      panelAddStudent.style.display = 'none';
    });
  }

  const btnAddLesson = document.getElementById('btn-add-lesson');
  if (btnAddLesson && panelAddLesson) {
    btnAddLesson.addEventListener('click', () => {
      panelAddLesson.style.display = panelAddLesson.style.display === 'none' ? 'flex' : 'none';
    });
  }
  const btnCancelNewLesson = document.getElementById('btn-cancel-new-lesson');
  if (btnCancelNewLesson && panelAddLesson) {
    btnCancelNewLesson.addEventListener('click', (e) => {
      e.preventDefault();
      panelAddLesson.style.display = 'none';
    });
  }

  // Toggle Archive Collapsible Panel
  const btnToggleArchive = document.getElementById('btn-toggle-archive');
  const panelArchive = document.getElementById('panel-archive');
  const archiveToggleIcon = document.getElementById('archive-toggle-icon');

  if (btnToggleArchive && panelArchive && archiveToggleIcon) {
    btnToggleArchive.addEventListener('click', () => {
      if (panelArchive.style.display === 'none') {
        panelArchive.style.display = 'block';
        archiveToggleIcon.innerText = 'Gizle ▴';
      } else {
        panelArchive.style.display = 'none';
        archiveToggleIcon.innerText = 'Göster ▾';
      }
    });
  }

  // Apply Role restrictions on load
  if (userRole === 'teacher') {
    const summaryCard = document.getElementById('erp-metrics-summary');
    if (summaryCard) summaryCard.style.display = 'none';
    
    const btnAddStd = document.getElementById('btn-add-student');
    if (btnAddStd) btnAddStd.style.display = 'none';
    
    const btnAddLes = document.getElementById('btn-add-lesson');
    if (btnAddLes) btnAddLes.style.display = 'none';

    const archiveCard = document.getElementById('btn-toggle-archive');
    if (archiveCard && archiveCard.parentElement) {
      archiveCard.parentElement.style.display = 'none';
    }
  }

  // Render Dashboard Summary Metrics & Tables
  window.renderErpDashboard = function() {
    if (!tbodyStudents || !listLessons) return;

    const students = erpDataObj.students || [];
    const lessons = erpDataObj.lessons || [];
    const archivedStudents = erpDataObj.archivedStudents || [];

    // Filter visible students for logged-in teacher context
    const visibleStudents = userRole === 'teacher'
      ? students.filter(s => s.teacherName === activeTeacher)
      : students;

    // Calculate Summary Metrics for selected Month
    const totalStudents = visibleStudents.length;
    const expectedRevenue = visibleStudents.reduce((sum, s) => sum + (s.monthlyFee || 0), 0);
    const paidRevenue = visibleStudents.filter(s => ((s.payments && s.payments[erpActiveMonth]) || 'Unpaid') === 'Paid').reduce((sum, s) => sum + (s.monthlyFee || 0), 0);
    const unpaidCount = visibleStudents.filter(s => ((s.payments && s.payments[erpActiveMonth]) || 'Unpaid') === 'Unpaid').length;

    document.getElementById('erp-stat-students').innerText = `${totalStudents} Öğrenci`;
    document.getElementById('erp-stat-revenue').innerText = `${expectedRevenue.toLocaleString()} ₺`;
    document.getElementById('erp-stat-paid').innerText = `${paidRevenue.toLocaleString()} ₺`;
    document.getElementById('erp-stat-unpaid').innerText = `${unpaidCount} Bekleyen`;

    // Render Student Table
    if (visibleStudents.length === 0) {
      tbodyStudents.innerHTML = `<tr><td colspan="7" style="text-align: center; padding: 2rem; color: #8b8b9f;">Kayıtlı öğrenci bulunmuyor.</td></tr>`;
    } else {
      let rowsHtml = '';
      visibleStudents.forEach((std) => {
        const payStatus = (std.payments && std.payments[erpActiveMonth]) || 'Unpaid';
        const att = (std.attendance && std.attendance[erpActiveMonth]) || { attended: 0, total: 4 };
        const notesVal = (std.notes && std.notes[erpActiveMonth]) || '';
        const progressVal = (std.progress && std.progress[erpActiveMonth]) || 0;

        const statusLabel = payStatus === 'Paid' ? 'Ödendi' : 'Ödenmedi';
        const statusBg = payStatus === 'Paid' ? 'rgba(16,185,129,0.1)' : 'rgba(239,68,68,0.1)';
        const statusColor = payStatus === 'Paid' ? '#10b981' : '#fca5a5';

        // Read-only payment status for teachers
        const paymentBtn = userRole === 'teacher'
          ? `<span style="background: ${statusBg}; color: ${statusColor}; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">${statusLabel}</span>`
          : `<button onclick="togglePaymentStatus('${std.id}')" style="background: ${statusBg}; color: ${statusColor}; border: 1px solid ${statusBg}; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; cursor: pointer;">${statusLabel} ⇅</button>`;

        // Attendance controller (+ / - buttons for teachers)
        const attendanceController = `
          <div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
            <button onclick="decrementAttendance('${std.id}')" style="background: #1f1f2e; color: #fff; border: 1px solid #2d2d42; width: 22px; height: 22px; border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.8rem;">-</button>
            <span style="font-weight: 600; font-family: monospace; font-size: 0.85rem; min-width: 32px; text-align: center;">${att.attended} / ${att.total}</span>
            <button onclick="incrementAttendance('${std.id}')" style="background: #1f1f2e; color: #fff; border: 1px solid #2d2d42; width: 22px; height: 22px; border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.8rem;">+</button>
          </div>
        `;

        const actionCell = userRole === 'teacher'
          ? `<span style="color: #6b6b7f; font-size: 0.75rem;">Yetki Yok</span>`
          : `<button onclick="deleteStudent('${std.id}')" style="background: rgba(239,68,68,0.1); color: #fca5a5; border: none; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.75rem; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">Arşivle</button>`;

        rowsHtml += `
          <tr style="border-bottom: 1px solid #161622;">
            <td style="padding: 1rem 0.5rem; color: #fff; font-weight: 600; cursor: pointer;" onclick="toggleStudentDetails('${std.id}')">
              <span style="border-bottom: 1px dashed rgba(212,175,55,0.4);">${std.name}</span>
              <span style="font-size: 0.75rem; color: #8b8b9f; margin-left: 0.35rem;">ℹ️ Detay</span>
            </td>
            <td style="padding: 1rem 0.5rem; font-family: monospace;">${std.phone}</td>
            <td style="padding: 1rem 0.5rem;">
              <span style="background: #161622; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; color: #d4af37; border: 1px solid #1f1f2e; display: inline-block; margin-bottom: 0.25rem;">${std.courseId.toUpperCase()}</span>
              <div style="font-size: 0.75rem; color: #8b8b9f;">Eğitmen: ${std.teacherName}</div>
            </td>
            <td style="padding: 1rem 0.5rem; text-align: right; color: #fff; font-weight: 600;">${std.monthlyFee} ₺</td>
            <td style="padding: 1rem 0.5rem; text-align: center;">${paymentBtn}</td>
            <td style="padding: 1rem 0.5rem; text-align: center;">${attendanceController}</td>
            <td style="padding: 1rem 0.5rem; text-align: center;">${actionCell}</td>
          </tr>
          <tr id="erp-details-row-${std.id}" style="display: none; background: #0b0b10;">
            <td colspan="7" style="padding: 1rem 1.5rem; border-bottom: 1px solid #161622;">
              <div style="display: flex; gap: 2rem; align-items: start; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 250px; display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600;">Ders Notları &amp; Ödevler (${erpActiveMonth}):</label>
                  <textarea id="erp-student-notes-${std.id}" rows="2" style="background: #161622; border: 1px solid #232335; color: #fff; padding: 0.5rem; border-radius: 6px; font-size: 0.8rem; width: 100%; resize: vertical;" placeholder="Örn: Bugün piyano tuşe egzersizleri yapıldı.">${notesVal}</textarea>
                </div>
                <div style="width: 220px; display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="font-size: 0.8rem; color: #a4a4b6; font-weight: 600;">Öğrenci Gelişimi: <strong id="erp-progress-lbl-${std.id}" style="color: #d4af37;">%${progressVal}</strong></label>
                  <input type="range" id="erp-student-progress-${std.id}" min="0" max="100" value="${progressVal}" style="width: 100%; accent-color: #d4af37;" oninput="document.getElementById('erp-progress-lbl-${std.id}').innerText = '%' + this.value" />
                </div>
                <div style="display: flex; align-items: flex-end; height: 100%; padding-top: 1.25rem;">
                  <button onclick="saveStudentProgress('${std.id}')" style="background: #d4af37; color: #000; border: none; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: background 0.2s;">Notları Kaydet 💾</button>
                </div>
              </div>
            </td>
          </tr>
        `;
      });
      tbodyStudents.innerHTML = rowsHtml;
    }

    // Render Teachers List and Dropdown Select options
    const teachers = erpDataObj.teachers || [];
    const selectStdTeacher = document.getElementById('erp-new-student-teacher');
    const selectLesTeacher = document.getElementById('erp-new-lesson-teacher');
    
    if (userRole === 'teacher') {
      if (selectStdTeacher) {
        selectStdTeacher.innerHTML = `<option value="${activeTeacher}">${activeTeacher}</option>`;
        selectStdTeacher.disabled = true;
      }
      if (selectLesTeacher) {
        selectLesTeacher.innerHTML = `<option value="${activeTeacher}">${activeTeacher}</option>`;
        selectLesTeacher.disabled = true;
      }
    } else {
      if (selectStdTeacher) {
        selectStdTeacher.innerHTML = teachers.map(t => `<option value="${t.name}">${t.name} (${t.specialty})</option>`).join('');
        selectStdTeacher.disabled = false;
      }
      if (selectLesTeacher) {
        selectLesTeacher.innerHTML = teachers.map(t => `<option value="${t.name}">${t.name} (${t.specialty})</option>`).join('');
        selectLesTeacher.disabled = false;
      }
    }

    const tbodyTeachers = document.getElementById('erp-teachers-list-tbody');
    if (tbodyTeachers) {
      if (teachers.length === 0) {
        tbodyTeachers.innerHTML = `<tr><td colspan="4" style="text-align: center; padding: 1rem; color: #6b6b7f;">Kayıtlı eğitmen bulunmuyor.</td></tr>`;
      } else {
        tbodyTeachers.innerHTML = teachers.map((t, idx) => `
          <tr style="border-bottom: 1px solid #161622;">
            <td style="padding: 0.5rem 0.25rem; color: #fff; font-weight: 600;">${t.name}</td>
            <td style="padding: 0.5rem 0.25rem;">${t.specialty}</td>
            <td style="padding: 0.5rem 0.25rem; text-align: right; font-weight: bold; color: #d4af37;">${t.hourlyRate} ₺</td>
            <td style="padding: 0.5rem 0.25rem; text-align: center;">
              <button onclick="deleteTeacher(${idx})" style="background: transparent; color: #fca5a5; border: none; font-size: 0.75rem; cursor: pointer;">Sil</button>
            </td>
          </tr>
        `).join('');
      }
    }

    // Render Payroll & Profit split breakdown (Admin only)
    const tbodyPayroll = document.getElementById('erp-payroll-tbody');
    if (tbodyPayroll && userRole === 'admin') {
      const instructors = {};
      
      // Initialize with all registered teachers
      teachers.forEach(t => {
        instructors[t.name] = {
          name: t.name,
          hourlyRate: t.hourlyRate,
          completedHours: 0,
          tuitionReceived: 0
        };
      });

      // Calculate hours from scheduled weekly lessons (1 lesson slot = 4 hours per month)
      lessons.forEach(les => {
        if (!instructors[les.teacherName]) {
          instructors[les.teacherName] = {
            name: les.teacherName,
            hourlyRate: 300,
            completedHours: 0,
            tuitionReceived: 0
          };
        }
        instructors[les.teacherName].completedHours += 4;
      });

      // Calculate tuition received from students assigned to this teacher
      students.forEach(std => {
        const payStatus = (std.payments && std.payments[erpActiveMonth]) || 'Unpaid';
        
        if (!instructors[std.teacherName]) {
          instructors[std.teacherName] = {
            name: std.teacherName,
            hourlyRate: 300,
            completedHours: 0,
            tuitionReceived: 0
          };
        }
        if (payStatus === 'Paid') {
          instructors[std.teacherName].tuitionReceived += (std.monthlyFee || 0);
        }
      });

      const instructorKeys = Object.keys(instructors);
      if (instructorKeys.length === 0) {
        tbodyPayroll.innerHTML = `<tr><td colspan="4" style="text-align: center; padding: 1.5rem; color: #6b6b7f;">Eğitmen kaydı bulunmuyor.</td></tr>`;
      } else {
        tbodyPayroll.innerHTML = instructorKeys.map(key => {
          const inst = instructors[key];
          const teacherCut = inst.completedHours * inst.hourlyRate;
          const academyCut = inst.tuitionReceived - teacherCut;
          
          return `
            <tr style="border-bottom: 1px solid #161622;">
              <td style="padding: 0.75rem 0.5rem; color: #fff; font-weight: 600;">${inst.name}</td>
              <td style="padding: 0.75rem 0.5rem; text-align: center; color: #fff; font-weight: 500;">${inst.completedHours} Saat</td>
              <td style="padding: 0.75rem 0.5rem; text-align: right; color: #10b981; font-weight: 700;">${teacherCut.toLocaleString()} ₺</td>
              <td style="padding: 0.75rem 0.5rem; text-align: right; color: ${academyCut >= 0 ? '#d4af37' : '#ef4444'}; font-weight: 700;">${academyCut.toLocaleString()} ₺</td>
            </tr>
          `;
        }).join('');
      }
    }

    // Render Archive Students Table
    const tbodyArchive = document.getElementById('erp-archive-tbody');
    if (tbodyArchive && userRole !== 'teacher') {
      if (archivedStudents.length === 0) {
        tbodyArchive.innerHTML = `<tr><td colspan="5" style="text-align: center; padding: 1.5rem; color: #6b6b7f;">Arşivlenmiş kayıt bulunmuyor.</td></tr>`;
      } else {
        tbodyArchive.innerHTML = archivedStudents.map((std) => `
          <tr style="border-bottom: 1px solid #161622; opacity: 0.75;">
            <td style="padding: 0.75rem 0.5rem; color: #fff; font-weight: 500;">${std.name}</td>
            <td style="padding: 0.75rem 0.5rem; font-family: monospace;">${std.phone}</td>
