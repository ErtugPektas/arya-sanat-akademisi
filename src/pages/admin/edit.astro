---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import path from 'path';

// Course parameter will be processed client-side or built statically
const courseId = Astro.url.searchParams.get('course') || 'baglama';
let course = null;
try {
  course = await getEntry('kurslar', courseId);
} catch (e) {
  console.error('getEntry error:', e);
}

if (!course) {
  try {
    const globCourses = import.meta.glob('../../content/kurslar/*.md', { eager: true });
    const matchKey = Object.keys(globCourses).find(k => k.endsWith(`/${courseId}.md`));
    if (matchKey) {
      const mod = globCourses[matchKey];
      course = {
        id: courseId,
        data: mod.frontmatter || mod
      };
    }
  } catch (err) {
    console.error('glob course match error:', err);
  }
}

if (!course) {
  course = {
    id: courseId,
    data: {
      title: "Yeni Kurs Dersi Kayseri | Arya Sanat Akademisi",
      description: "Kayseri Kocasinan yeni kurs dersi — Arya Sanat Akademisi.",
      keywords: "yeni kurs dersi kayseri",
      badge: "⭐ Yeni Kurs",
      heroTitle: "Yeni Kurs Dersi",
      heroTitleHighlight: "Kayseri Kocasinan",
      heroDesc: "Yeni kurs tanıtım açıklaması.",
      image: "/assets/kurslar/piyano-kurs.jpg",
      videoPreview: "",
      duration: "45 dk / ders",
      frequency: "Haftada 1 ders",
      level: "Başlangıç",
      certificate: "Katılım Belgesi",
      leadText: "Yeni Kurs leadText",
      teacher: {
        name: "Eğitmen Adı",
        specialty: "Uzmanlık Alanı",
        image: "/assets/teachers/default.jpg",
        tags: ["Eğitmen"],
        bio1: "Eğitmen biyografisi paragrafı.",
        bio2: ""
      }
    },
    body: "Yeni kurs detay markdown açıklaması buraya yazılacaktır."
  };
}

const { data, body } = course;
---

<Layout title={`${data.heroTitle} Düzenle | Yönetim Paneli`} description="Kurs Düzenleme Alanı">
  <link rel="stylesheet" href="/css/style.css" slot="head" />

  <div class="admin-container" style="min-height: 100vh; padding: 0 0 4rem 0; background: #07070a; color: #fff; font-family: sans-serif;">
    
    <!-- CUSTOM ADMIN TOPBAR -->
    <div style="background: #101016; border-bottom: 1px solid #1f1f2e; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(0,0,0,0.15); margin-bottom: 3rem;">
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <span style="font-size: 1.5rem; color: #d4af37;">♩</span>
        <div>
          <strong style="color: #fff; font-size: 1.05rem; display: block; font-weight: 700;">Arya Sanat</strong>
          <span style="color: #d4af37; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">Yönetim Paneli</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 1.5rem;">
        <a href="/" target="_blank" style="color: #b4b4c6; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#b4b4c6'"> Canlı Siteyi Gör 🌐</a>
        <a 
          href="/admin?action=logout" 
          style="background: rgba(239, 68, 68, 0.12); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.25); padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
          onmouseover="this.style.background='rgba(239, 68, 68, 0.2)'; this.style.borderColor='rgba(239,68,68,0.4)';"
          onmouseout="this.style.background='rgba(239, 68, 68, 0.12)'; this.style.borderColor='rgba(239,68,68,0.25)';"
        >
          Güvenli Çıkış 🚪
        </a>
      </div>
    </div>

    <div style="max-width: 900px; margin: 0 auto; padding: 0 1.5rem;">
      
      <!-- HEADER -->
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1f1f2e; padding-bottom: 1.5rem; margin-bottom: 3rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <a href="/admin" style="color: #8b8b9f; text-decoration: none; font-size: 0.9rem; display: flex; align-items: center; gap: 0.25rem; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8b8b9f'">
            ← Yönetim Masasına Geri Dön
          </a>
          <h1 style="font-size: 2rem; font-weight: 800; margin-top: 0.75rem; color: #fff; letter-spacing: -0.01em;">{data.heroTitle} Düzenle</h1>
        </div>
        <button 
          id="btn-save" 
          style="background: linear-gradient(135deg, #d4af37 0%, #aa841c 100%); color: #000; border: none; padding: 0.85rem 1.75rem; border-radius: 8px; font-size: 0.95rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s; box-shadow: 0 4px 15px rgba(212,175,55,0.25);"
          onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(212,175,55,0.4)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(212,175,55,0.25)';"
        >
          <span>Kaydet ve Yayınla 🚀</span>
        </button>
      </div>

      <!-- FORM -->
      <form id="course-form" style="display: flex; flex-direction: column; gap: 2.5rem;">
        <input type="hidden" name="courseId" value={courseId} />

        <!-- 1. SEO AYARLARI -->
        <fieldset style="border: 1px solid #232330; border-radius: 8px; padding: 2rem; background: #13131a; display: flex; flex-direction: column; gap: 1.5rem;">
          <legend style="color: #d4af37; padding: 0 0.5rem; font-weight: 600; font-size: 1.1rem;">🔍 SEO & Meta Ayarları</legend>
          
          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">SEO Başlığı (Sayfa Sekme Başlığı)</label>
            <input type="text" name="title" value={data.title} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; outline: none; width: 100%;" />
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">SEO Açıklaması (Google Arama Özeti)</label>
            <textarea name="description" rows="3" required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; outline: none; width: 100%; resize: vertical; font-family: sans-serif;">{data.description}</textarea>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Anahtar Kelimeler (Virgülle Ayırın)</label>
            <input type="text" name="keywords" value={data.keywords} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; outline: none; width: 100%;" />
          </div>
        </fieldset>

        <!-- 2. GİRİŞ & HERO BÖLÜMÜ -->
        <fieldset style="border: 1px solid #232330; border-radius: 8px; padding: 2rem; background: #13131a; display: flex; flex-direction: column; gap: 1.5rem;">
          <legend style="color: #d4af37; padding: 0 0.5rem; font-weight: 600; font-size: 1.1rem;">⚡ Hero & Tanıtım Ayarları</legend>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Kategori Rozeti (Emoji ile)</label>
              <input type="text" name="badge" value={data.badge} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem;" />
            </div>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Kurs Başlığı</label>
              <input type="text" name="heroTitle" value={data.heroTitle} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem;" />
            </div>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Başlık Vurgusu (Örn: Kayseri Kocasinan)</label>
            <input type="text" name="heroTitleHighlight" value={data.heroTitleHighlight} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem;" />
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Hero Kısa Açıklaması</label>
            <textarea name="heroDesc" rows="2" required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%; font-family: sans-serif; resize: vertical;">{data.heroDesc}</textarea>
          </div>

          <div style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1; min-width: 250px;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Kurs Görsel Yolu (URL veya Assets Yolu)</label>
              <div style="display: flex; gap: 0.5rem;">
                <input type="text" id="input-image" name="image" value={data.image} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%;" oninput="document.getElementById('preview-image').src = this.value" />
                <button type="button" onclick="document.getElementById('file-course-image').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Görsel Yükle 📁</button>
                <input type="file" id="file-course-image" style="display: none;" accept="image/*" onchange="uploadFile(this, 'input-image', 'preview-image')" />
              </div>
            </div>
            <div style="width: 120px; height: 80px; border-radius: 8px; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <img id="preview-image" src={data.image} style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23888\' stroke-width=\'2\' stroke-linecap=\'round\' stroke-linejoin=\'round\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\' ry=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg>'" />
            </div>
          </div>

          <div style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1; min-width: 250px;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Kurs Kısa Video Önizlemesi (MP4 - Opsiyonel)</label>
              <div style="display: flex; gap: 0.5rem;">
                <input type="text" id="input-video-preview" name="videoPreview" value={data.videoPreview || ''} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%;" oninput="document.getElementById('preview-video').src = this.value" />
                <button type="button" onclick="document.getElementById('file-course-video').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Video Yükle 📁</button>
                <input type="file" id="file-course-video" style="display: none;" accept="video/*" onchange="uploadFile(this, 'input-video-preview', 'preview-video')" />
              </div>
            </div>
            <div style="width: 120px; height: 80px; border-radius: 8px; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <video id="preview-video" src={data.videoPreview} loop muted autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; display: data.videoPreview ? 'block' : 'none';" onerror="this.style.display='none'" onloadeddata="this.style.display='block'"></video>
            </div>
          </div>
        </fieldset>

        <!-- 3. DETAY KARTLARI & ÖZETLER -->
        <fieldset style="border: 1px solid #232330; border-radius: 8px; padding: 2rem; background: #13131a; display: flex; flex-direction: column; gap: 1.5rem;">
          <legend style="color: #d4af37; padding: 0 0.5rem; font-weight: 600; font-size: 1.1rem;">⏱️ Özet & Detay Bilgileri</legend>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Ders Süresi</label>
              <input type="text" name="duration" value={data.duration} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Ders Sıklığı</label>
              <input type="text" name="frequency" value={data.frequency} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Seviye Aralığı</label>
              <input type="text" name="level" value={data.level} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Sertifika Durumu</label>
              <input type="text" name="certificate" value={data.certificate} required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Özet Giriş Yazısı (Lead Text)</label>
            <textarea name="leadText" rows="2" required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%; font-family: sans-serif; resize: vertical;">{data.leadText}</textarea>
          </div>
        </fieldset>

        <!-- 4. EĞİTMEN BİLGİLERİ -->
        <fieldset style="border: 1px solid #232330; border-radius: 8px; padding: 2rem; background: #13131a; display: flex; flex-direction: column; gap: 1.5rem;">
          <legend style="color: #d4af37; padding: 0 0.5rem; font-weight: 600; font-size: 1.1rem;">👨‍🏫 Eğitmen Bilgileri</legend>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Adı</label>
              <input type="text" name="teacher_name" value={data.teacher?.name || ''} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Uzmanlık Alanı</label>
              <input type="text" name="teacher_specialty" value={data.teacher?.specialty || ''} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px;" />
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">
            <div style="display: flex; gap: 1.25rem; align-items: flex-end; width: 100%;">
              <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1;">
                <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Görsel Yolu (URL veya Assets Yolu)</label>
                <div style="display: flex; gap: 0.5rem;">
                  <input type="text" id="input-teacher-image" name="teacher_image" value={data.teacher?.image || ''} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; width: 100%;" oninput="document.getElementById('preview-teacher-image').src = this.value" />
                  <button type="button" onclick="document.getElementById('file-teacher-image').click()" style="background: #1c1c28; color: #d4af37; border: 1px solid #2d2d3d; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap;">Görsel Yükle 📁</button>
                  <input type="file" id="file-teacher-image" style="display: none;" accept="image/*" onchange="uploadFile(this, 'input-teacher-image', 'preview-teacher-image')" />
                </div>
              </div>
              <div style="width: 70px; height: 70px; border-radius: 50%; overflow: hidden; border: 1px solid #2d2d3d; background: #101016; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <img id="preview-teacher-image" src={data.teacher?.image || '/assets/teachers/default.jpg'} style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23888\' stroke-width=\'2\' stroke-linecap=\'round\' stroke-linejoin=\'round\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\' ry=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg>'" />
              </div>
            </div>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Etiketleri (Virgülle Ayırın)</label>
              <input type="text" name="teacher_tags" value={data.teacher?.tags ? data.teacher.tags.join(', ') : ''} style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; height: 42px; margin-top: 1.5rem;" />
            </div>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Biyografisi (Paragraf 1)</label>
            <textarea name="teacher_bio1" rows="3" style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%; font-family: sans-serif; resize: vertical;">{data.teacher?.bio1 || ''}</textarea>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitmen Biyografisi (Paragraf 2 - Opsiyonel)</label>
            <textarea name="teacher_bio2" rows="3" style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%; font-family: sans-serif; resize: vertical;">{data.teacher?.bio2 || ''}</textarea>
          </div>
        </fieldset>

        <!-- 5. DETAYLI METİN İÇERİĞİ -->
        <fieldset style="border: 1px solid #232330; border-radius: 8px; padding: 2rem; background: #13131a; display: flex; flex-direction: column; gap: 1.5rem;">
          <legend style="color: #d4af37; padding: 0 0.5rem; font-weight: 600; font-size: 1.1rem;">📝 Detaylı Sayfa İçeriği (Markdown)</legend>
          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="font-weight: 500; font-size: 0.9rem; color: #b4b4c6;">Eğitim Hakkında Bölümü İçin Alt Yazılar & Metinler</label>
            <textarea name="bodyContent" rows="8" required style="background: #1a1a24; border: 1px solid #2d2d3d; color: #fff; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.95rem; width: 100%; font-family: monospace; resize: vertical; line-height: 1.5;">{body}</textarea>
          </div>
        </fieldset>

      </form>
    </div>
  </div>

  <!-- SAVING LOGIC -->
  <script is:inline>
    async function uploadFile(inputEl, textInputId, previewImgId) {
      if (!inputEl.files || !inputEl.files[0]) return;
      
      const file = inputEl.files[0];
      const btn = inputEl.previousElementSibling;
      const originalText = btn ? btn.innerText : 'Yükle';
      if (btn) {
        btn.disabled = true;
        btn.innerText = 'Yükleniyor... ⏳';
      }
      
      const setUploadedUrl = (url) => {
        const inputTarget = document.getElementById(textInputId);
        if (inputTarget) inputTarget.value = url;
        const previewEl = document.getElementById(previewImgId);
        if (previewEl) {
          previewEl.src = url;
          if (previewEl.tagName === 'VIDEO') {
            previewEl.style.display = 'block';
            previewEl.load();
            previewEl.play().catch(e => console.log('Autoplay check:', e));
          } else {
            previewEl.style.display = 'block';
          }
        }
        alert('✓ Dosya başarıyla yüklendi ve eklendi!');
      };

      try {
        const formData = new FormData();
        formData.append('file', file);

        const response = await fetch('/api/upload-image', {
          method: 'POST',
          body: formData
        });
        
        const result = await response.json();
        
        if (response.ok && result.success && result.url) {
          setUploadedUrl(result.url);
        } else {
          const reader = new FileReader();
          reader.onload = (e) => setUploadedUrl(e.target.result);
          reader.readAsDataURL(file);
        }
      } catch (err) {
        const reader = new FileReader();
        reader.onload = (e) => setUploadedUrl(e.target.result);
        reader.readAsDataURL(file);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerText = originalText;
        }
        inputEl.value = '';
      }
    }
    
    window.uploadFile = uploadFile;

    const saveBtn = document.getElementById('btn-save');
    const form = document.getElementById('course-form');

    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const originalText = saveBtn.innerHTML;
      saveBtn.innerHTML = '<span>Yayınlanıyor... ⏳</span>';

      const formData = new FormData(form);
      const payload = {};
      formData.forEach((value, key) => {
        payload[key] = value;
      });

      try {
        const response = await fetch('/api/save-course', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (response.ok) {
          alert('Başarıyla kaydedildi ve yayınlandı! Değişikliklerin canlı sitede görünmesi 30-45 saniye sürebilir.');
          window.location.href = '/admin';
        } else {
          alert('Hata: ' + (result.error || 'Bilinmeyen bir hata oluştu.'));
          saveBtn.disabled = false;
          saveBtn.innerHTML = originalText;
        }
      } catch (err) {
        alert('İletişim hatası: ' + err.message);
        saveBtn.disabled = false;
        saveBtn.innerHTML = originalText;
      }
    });
  </script>
</Layout>
